<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>后台管理 - 标签管理</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#6366f1',
            dark: {
              100: '#1e293b',
              200: '#172033',
              300: '#0f1115',
              400: '#0a0c10',
            }
          }
        }
      }
    };
  </script>
  <style>
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }
    .sidebar-item {
      transition: all 0.3s ease;
    }
    .sidebar-item:hover {
      background: rgba(99, 102, 241, 0.1);
      border-right: 3px solid #6366f1;
    }
    .sidebar-item.active {
      background: rgba(99, 102, 241, 0.2);
      border-right: 3px solid #6366f1;
      color: #818cf8;
    }
  </style>
</head>
<body class="bg-[#0f1115] text-gray-300 min-h-screen">
  <header class="sticky top-0 z-50 bg-[#0f1115]/80 backdrop-blur-xl border-b border-gray-800">
    <div class="flex items-center justify-between px-6 h-16">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
        </div>
        <h1 class="text-xl font-bold text-white">DevLog 后台管理</h1>
      </div>
      <div class="flex items-center gap-4">
        <button onclick="goBack()" class="flex items-center gap-2 px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          返回
        </button>
        <button onclick="logout()" class="flex items-center gap-2 px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
          </svg>
          退出
        </button>
      </div>
    </div>
  </header>

  <div class="flex min-h-[calc(100vh-64px)]">
    <aside class="w-64 bg-[#0a0c10] border-r border-gray-800">
      <nav class="py-4">
        <div class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3" onclick="goToDashboard()">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
          </svg>
          <span>概览</span>
        </div>
        <div class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3" onclick="goToPosts()">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <span>文章管理</span>
        </div>
        <div class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3" onclick="goToCategories()">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
          </svg>
          <span>分类管理</span>
        </div>
        <div class="sidebar-item active px-6 py-3 cursor-pointer flex items-center gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
          </svg>
          <span>标签管理</span>
        </div>
        <div class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3" onclick="goToSettings()">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <span>系统设置</span>
        </div>
      </nav>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-white">标签管理</h2>
        <button onclick="openEditor()" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-all">
          新增标签
        </button>
      </div>

      <!-- 标签云展示 -->
      <div class="bg-[#111] border border-gray-800 rounded-xl p-6 mb-6">
        <h3 class="text-lg font-bold text-white mb-4">标签云</h3>
        <div id="tagCloud" class="flex flex-wrap gap-3">
          <!-- 动态生成标签云 -->
        </div>
      </div>

      <div class="bg-[#111] border border-gray-800 rounded-xl p-4 mb-6">
        <input
          id="searchInput"
          type="text"
          placeholder="搜索标签名称 / Slug"
          class="w-full px-4 py-2.5 bg-gray-800/50 border border-gray-700 rounded-lg text-white placeholder-gray-500 focus:outline-none focus:border-indigo-500"
          oninput="renderTable()"
        />
      </div>

      <div class="bg-[#111] border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gray-900/50 text-gray-400">
            <tr>
              <th class="text-left px-6 py-4">名称</th>
              <th class="text-left px-6 py-4">Slug</th>
              <th class="text-left px-6 py-4">颜色</th>
              <th class="text-left px-6 py-4">文章数</th>
              <th class="text-right px-6 py-4">操作</th>
            </tr>
          </thead>
          <tbody id="tableBody" class="divide-y divide-gray-800"></tbody>
        </table>
      </div>
    </main>
  </div>

  <div id="editorModal" class="fixed inset-0 bg-black/60 hidden items-center justify-center p-4 z-50">
    <div class="w-full max-w-xl bg-[#111] border border-gray-800 rounded-xl p-6">
      <h3 id="editorTitle" class="text-lg font-bold text-white mb-5">新增标签</h3>
      <div class="space-y-4">
        <div>
          <label class="block text-sm text-gray-400 mb-2">标签名称</label>
          <input id="tagName" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-2">Slug</label>
          <input id="tagSlug" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-2">颜色</label>
          <input id="tagColor" type="color" class="w-full h-10 bg-gray-800 border border-gray-700 rounded-lg p-1" value="#6366f1" />
        </div>
      </div>
      <div class="flex justify-end gap-3 mt-6">
        <button onclick="closeEditor()" class="px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg">取消</button>
        <button onclick="saveTag()" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg">保存</button>
      </div>
    </div>
  </div>

  <script>
    const token = localStorage.getItem('token');
    if (!token) {
      window.location.href = '/admin';
    }

    let tags = [];
    let posts = [];
    let editingId = '';
    let slugTouched = false;

    const searchInput = document.getElementById('searchInput');
    const tagCloudEl = document.getElementById('tagCloud');
    const editorModal = document.getElementById('editorModal');
    const editorTitle = document.getElementById('editorTitle');
    const tagNameInput = document.getElementById('tagName');
    const tagSlugInput = document.getElementById('tagSlug');
    const tagColorInput = document.getElementById('tagColor');

    function escapeHtml(input) {
      return String(input || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function slugify(input) {
      return String(input || '')
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    function nextId(list, prefix) {
      const nums = list
        .map((item) => Number(item && item.id))
        .filter((n) => Number.isFinite(n));
      if (nums.length) {
        return String(Math.max(...nums) + 1);
      }
      return `${prefix}-${Date.now()}`;
    }

    function resolvePostTags(post) {
      if (Array.isArray(post.tags)) return post.tags;
      if (Array.isArray(post.tagIds)) return post.tagIds;
      return [];
    }

    function countUsage(tagId) {
      return posts.reduce((total, post) => {
        return resolvePostTags(post).includes(tagId) ? total + 1 : total;
      }, 0);
    }

    async function fetchData(type) {
      const response = await fetch(`/api/data/${type}`, {
        headers: {
          Authorization: `Bearer ${token}`,
        },
      });
      if (response.status === 401) {
        logout();
        return [];
      }
      if (!response.ok) {
        throw new Error(`加载 ${type} 失败`);
      }
      return await response.json();
    }

    async function saveData(type, data) {
      const response = await fetch(`/api/data/${type}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify(data),
      });
      if (!response.ok) {
        throw new Error(`保存 ${type} 失败`);
      }
    }

    function renderTagCloud() {
      if (!tags.length) {
        tagCloudEl.innerHTML = '<span class="text-gray-500">暂无标签</span>';
        return;
      }

      const maxUsage = Math.max(...tags.map(t => countUsage(t.id)), 1);
      const sortedTags = tags.slice().sort((a, b) => countUsage(b.id) - countUsage(a.id));

      tagCloudEl.innerHTML = sortedTags.map(tag => {
        const usage = countUsage(tag.id);
        const size = 0.875 + (usage / maxUsage) * 0.625; // 14px to 24px
        const color = tag.color || '#6366f1';
        const opacity = 0.4 + (usage / maxUsage) * 0.6;
        
        return `
          <span 
            class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full transition-all hover:scale-110 cursor-pointer"
            style="font-size: ${size}rem; background: ${color}20; color: ${color}; border: 1px solid ${color}40"
            title="${usage} 篇文章"
          >
            <span style="opacity: ${opacity}">#</span>
            ${escapeHtml(tag.name)}
            <span class="text-xs opacity-60">(${usage})</span>
          </span>
        `;
      }).join('');
    }

    function renderTable() {
      const keyword = String(searchInput.value || '').trim().toLowerCase();
      const tbody = document.getElementById('tableBody');
      const list = tags
        .slice()
        .filter((item) => {
          if (!keyword) return true;
          const name = String(item.name || '').toLowerCase();
          const slug = String(item.slug || '').toLowerCase();
          return name.includes(keyword) || slug.includes(keyword);
        })
        .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')));

      if (!list.length) {
        tbody.innerHTML = `
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-500">暂无标签数据</td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = list.map((item) => {
        const usage = countUsage(item.id);
        const color = item.color || '#6366f1';
        return `
          <tr class="hover:bg-gray-800/20">
            <td class="px-6 py-4 text-gray-200 font-medium">${escapeHtml(item.name)}</td>
            <td class="px-6 py-4 text-gray-400">${escapeHtml(item.slug)}</td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center gap-2 text-gray-300">
                <i class="w-3 h-3 rounded-full" style="background:${escapeHtml(color)}"></i>
                ${escapeHtml(color)}
              </span>
            </td>
            <td class="px-6 py-4 text-gray-300">${usage}</td>
            <td class="px-6 py-4 text-right space-x-2">
              <button onclick="openEditor('${escapeHtml(String(item.id))}')" class="px-3 py-1.5 bg-gray-700 hover:bg-gray-600 text-gray-200 rounded">编辑</button>
              <button onclick="deleteTag('${escapeHtml(String(item.id))}')" class="px-3 py-1.5 bg-red-600/80 hover:bg-red-600 text-white rounded">删除</button>
            </td>
          </tr>
        `;
      }).join('');
    }

    function openEditor(id) {
      editingId = id || '';
      slugTouched = false;
      const item = tags.find((tag) => String(tag.id) === String(editingId));

      editorTitle.textContent = item ? '编辑标签' : '新增标签';
      tagNameInput.value = item ? String(item.name || '') : '';
      tagSlugInput.value = item ? String(item.slug || '') : '';
      tagColorInput.value = item ? String(item.color || '#6366f1') : '#6366f1';
      editorModal.classList.remove('hidden');
      editorModal.classList.add('flex');
      tagNameInput.focus();
    }

    function closeEditor() {
      editorModal.classList.add('hidden');
      editorModal.classList.remove('flex');
      editingId = '';
    }

    async function saveTag() {
      const name = String(tagNameInput.value || '').trim();
      const slug = String(tagSlugInput.value || '').trim() || slugify(name);
      const color = String(tagColorInput.value || '#6366f1').trim() || '#6366f1';
      
      if (!name) {
        alert('标签名称不能为空');
        return;
      }
      if (!slug) {
        alert('Slug 不能为空');
        return;
      }

      const duplicated = tags.some((item) =>
        String(item.slug || '').toLowerCase() === slug.toLowerCase()
        && String(item.id) !== String(editingId)
      );
      if (duplicated) {
        alert('Slug 已存在，请更换');
        return;
      }

      if (editingId) {
        const index = tags.findIndex((item) => String(item.id) === String(editingId));
        if (index >= 0) {
          tags[index] = {
            ...tags[index],
            name,
            slug,
            color,
          };
        }
      } else {
        tags.push({
          id: nextId(tags, 'tag'),
          name,
          slug,
          color,
        });
      }

      try {
        await saveData('tags', tags);
        closeEditor();
        renderTable();
        renderTagCloud();
      } catch (error) {
        console.error(error);
        alert('保存标签失败');
      }
    }

    async function deleteTag(id) {
      const usage = countUsage(id);
      if (usage > 0) {
        alert(`该标签已被 ${usage} 篇文章使用，不能删除`);
        return;
      }
      if (!confirm('确定删除该标签吗？')) return;

      tags = tags.filter((item) => String(item.id) !== String(id));
      try {
        await saveData('tags', tags);
        renderTable();
      } catch (error) {
        console.error(error);
        alert('删除标签失败');
      }
    }

    async function initPage() {
      try {
        const [tagData, postData] = await Promise.all([
          fetchData('tags'),
          fetchData('posts'),
        ]);
        tags = Array.isArray(tagData) ? tagData : [];
        posts = Array.isArray(postData) ? postData : [];
        renderTable();
        renderTagCloud();
      } catch (error) {
        console.error(error);
        document.getElementById('tableBody').innerHTML = `
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-red-400">加载数据失败，请刷新重试</td>
          </tr>
        `;
      }
    }

    tagNameInput.addEventListener('input', () => {
      if (slugTouched) return;
      tagSlugInput.value = slugify(tagNameInput.value);
    });
    tagSlugInput.addEventListener('input', () => {
      slugTouched = true;
    });

    function goBack() {
      window.location.href = '/admin/dashboard.html';
    }
    function goToDashboard() {
      window.location.href = '/admin/dashboard.html';
    }
    function goToPosts() {
      window.location.href = '/admin/posts.html';
    }
    function goToCategories() {
      window.location.href = '/admin/categories.html';
    }
    function goToSettings() {
      window.location.href = '/admin/settings.html';
    }
    function logout() {
      localStorage.removeItem('token');
      window.location.href = '/admin';
    }

    initPage();
  </script>
</body>
</html>
