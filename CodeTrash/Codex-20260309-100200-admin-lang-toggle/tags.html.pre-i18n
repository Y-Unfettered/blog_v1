<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DevLog Tags</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '#6366f1',
            dark: {
              bg: '#0a0a0a',
              surface: '#111111',
              border: '#1f1f1f',
            },
          },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/admin/admin-common.css">
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-[#0a0a0a] dark:text-gray-100">
  <div id="admin-app"></div>

  <script src="/admin/admin-common.js"></script>
  <script>
    if (!window.AdminApp || !AdminApp.requireAuth()) {
      throw new Error('Missing admin auth context.');
    }

    const layout = AdminApp.mountPage({
      active: 'tags',
      title: 'Tag Management',
      description: 'Manage tag metadata, usage, and article references from one place. Deletion is blocked when a tag is still referenced by posts.',
      actions: [
        {
          id: 'reload-tags-btn',
          label: 'Reload',
          className: 'rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800',
        },
        {
          id: 'create-tag-btn',
          label: 'New Tag',
          className: 'rounded-xl bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-lg shadow-indigo-500/20 transition-colors hover:bg-indigo-700',
        },
      ],
    });

    layout.content.innerHTML = `
      <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <article class="admin-panel metric-card p-5">
          <div class="text-sm text-gray-500 dark:text-gray-400">Total Tags</div>
          <div id="metric-total-tags" class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">--</div>
          <div class="mt-3 text-sm text-gray-500 dark:text-gray-400">All stored tag records.</div>
        </article>
        <article class="admin-panel metric-card p-5">
          <div class="text-sm text-gray-500 dark:text-gray-400">Used Tags</div>
          <div id="metric-used-tags" class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">--</div>
          <div class="mt-3 text-sm text-gray-500 dark:text-gray-400">Tags referenced by at least one post.</div>
        </article>
        <article class="admin-panel metric-card p-5">
          <div class="text-sm text-gray-500 dark:text-gray-400">Unused Tags</div>
          <div id="metric-unused-tags" class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">--</div>
          <div class="mt-3 text-sm text-gray-500 dark:text-gray-400">Safe candidates for cleanup.</div>
        </article>
        <article class="admin-panel metric-card p-5">
          <div class="text-sm text-gray-500 dark:text-gray-400">Most Used</div>
          <div id="metric-top-tag" class="mt-2 text-xl font-bold text-gray-900 dark:text-white">--</div>
          <div id="metric-top-tag-usage" class="mt-3 text-sm text-gray-500 dark:text-gray-400">--</div>
        </article>
      </section>

      <section class="admin-panel mt-6 p-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-md flex-1">
            <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="tag-search-input">Search</label>
            <input id="tag-search-input" class="input-control" type="search" placeholder="Search by tag name, slug, or id">
          </div>
          <div class="text-sm text-gray-500 dark:text-gray-400">
            Usage is calculated from current posts instead of trusting stale counters in seed data.
          </div>
        </div>
        <div id="tag-list" class="mt-6 grid gap-4 xl:grid-cols-2"></div>
      </section>

      <div id="tag-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 px-4 py-6 backdrop-blur-sm">
        <div class="admin-panel w-full max-w-lg p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="admin-kicker text-gray-500 dark:text-gray-400">Tag Editor</div>
              <h2 id="tag-modal-title" class="mt-1 text-xl font-semibold text-gray-900 dark:text-white">Create Tag</h2>
            </div>
            <button id="tag-modal-close" type="button" class="rounded-xl border border-gray-200 px-3 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800">Close</button>
          </div>
          <form id="tag-form" class="mt-6 grid gap-4" novalidate>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="tag-name-input">Name</label>
              <input id="tag-name-input" class="input-control" type="text" maxlength="80" required>
            </div>
            <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_140px]">
              <div>
                <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="tag-slug-input">Slug</label>
                <input id="tag-slug-input" class="input-control" type="text" maxlength="80" required>
              </div>
              <div>
                <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="tag-order-input">Order</label>
                <input id="tag-order-input" class="input-control" type="number" min="1" step="1">
              </div>
            </div>
            <div class="grid gap-4 md:grid-cols-[160px_minmax(0,1fr)]">
              <div>
                <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="tag-color-input">Color</label>
                <input id="tag-color-input" class="input-control h-[52px] px-2" type="color" value="#6366f1">
              </div>
              <div class="rounded-2xl border border-dashed border-gray-200 p-4 dark:border-gray-700">
                <div class="text-sm font-medium text-gray-700 dark:text-gray-300">Preview</div>
                <div class="mt-3">
                  <span id="tag-color-preview" class="inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-sm font-medium" style="background: rgba(99, 102, 241, 0.12); color: #6366f1;">
                    <span class="h-2.5 w-2.5 rounded-full" style="background: currentColor;"></span>
                    <span id="tag-color-preview-name">New Tag</span>
                  </span>
                </div>
              </div>
            </div>
            <div class="flex justify-end gap-3 pt-2">
              <button id="tag-delete-btn" type="button" class="hidden rounded-xl border border-rose-200 px-4 py-2 text-sm font-medium text-rose-700 transition-colors hover:bg-rose-50 dark:border-rose-900/50 dark:text-rose-300 dark:hover:bg-rose-500/10">Delete</button>
              <button type="submit" class="rounded-xl bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-lg shadow-indigo-500/20 transition-colors hover:bg-indigo-700">Save Tag</button>
            </div>
          </form>
        </div>
      </div>
    `;

    const state = {
      tags: [],
      posts: [],
      editingId: '',
      slugTouched: false,
      search: '',
      usageMap: new Map(),
    };

    const elements = {
      searchInput: document.getElementById('tag-search-input'),
      list: document.getElementById('tag-list'),
      modal: document.getElementById('tag-modal'),
      modalTitle: document.getElementById('tag-modal-title'),
      closeModalButton: document.getElementById('tag-modal-close'),
      form: document.getElementById('tag-form'),
      nameInput: document.getElementById('tag-name-input'),
      slugInput: document.getElementById('tag-slug-input'),
      orderInput: document.getElementById('tag-order-input'),
      colorInput: document.getElementById('tag-color-input'),
      colorPreview: document.getElementById('tag-color-preview'),
      colorPreviewName: document.getElementById('tag-color-preview-name'),
      deleteButton: document.getElementById('tag-delete-btn'),
    };

    function slugify(value) {
      const normalized = String(value || '')
        .trim()
        .toLowerCase()
        .normalize('NFKD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\u4e00-\u9fff]+/g, '-')
        .replace(/^-+|-+$/g, '');
      return normalized || `tag-${Date.now()}`;
    }

    function normalizeColor(value) {
      const color = String(value || '').trim();
      return /^#[0-9a-f]{6}$/i.test(color) ? color : '#6366f1';
    }

    function resolvePostTags(post) {
      if (Array.isArray(post.tags)) return post.tags;
      if (Array.isArray(post.tagIds)) return post.tagIds;
      return [];
    }

    function buildUsageMap(posts) {
      const usage = new Map();
      (Array.isArray(posts) ? posts : []).forEach(function eachPost(post) {
        resolvePostTags(post).forEach(function eachTag(tagId) {
          const key = String(tagId);
          usage.set(key, (usage.get(key) || 0) + 1);
        });
      });
      return usage;
    }

    function getUsage(tagId) {
      return state.usageMap.get(String(tagId)) || 0;
    }

    function syncMetrics() {
      const totalTags = state.tags.length;
      const usedTags = state.tags.filter(function isUsed(tag) {
        return getUsage(tag.id) > 0;
      }).length;
      const unusedTags = totalTags - usedTags;
      const topTag = state.tags
        .slice()
        .sort(function byUsage(a, b) {
          const usageDiff = getUsage(b.id) - getUsage(a.id);
          if (usageDiff !== 0) return usageDiff;
          return String(a.name || '').localeCompare(String(b.name || ''));
        })[0];

      document.getElementById('metric-total-tags').textContent = String(totalTags);
      document.getElementById('metric-used-tags').textContent = String(usedTags);
      document.getElementById('metric-unused-tags').textContent = String(Math.max(0, unusedTags));
      document.getElementById('metric-top-tag').textContent = topTag ? (topTag.name || topTag.slug || topTag.id) : '--';
      document.getElementById('metric-top-tag-usage').textContent = topTag ? `${getUsage(topTag.id)} linked posts` : 'No usage data';
    }

    function updatePreview() {
      const color = normalizeColor(elements.colorInput.value);
      const name = String(elements.nameInput.value || '').trim() || 'New Tag';
      elements.colorPreview.style.background = `${color}1f`;
      elements.colorPreview.style.color = color;
      elements.colorPreviewName.textContent = name;
    }

    function sortTags(list) {
      return list.slice().sort(function byOrder(a, b) {
        const orderDiff = (Number(a.order) || 0) - (Number(b.order) || 0);
        if (orderDiff !== 0) return orderDiff;
        return String(a.name || '').localeCompare(String(b.name || ''));
      });
    }

    function renderTagList() {
      const keyword = String(state.search || '').trim().toLowerCase();
      const filtered = sortTags(state.tags).filter(function matchTag(tag) {
        if (!keyword) return true;
        const haystack = [
          tag.id,
          tag.name,
          tag.slug,
        ].map(function stringify(value) {
          return String(value || '').toLowerCase();
        }).join(' ');
        return haystack.includes(keyword);
      });

      if (!filtered.length) {
        elements.list.innerHTML = `
          <div class="rounded-2xl border border-dashed border-gray-200 px-6 py-12 text-center text-sm text-gray-500 dark:border-gray-700 dark:text-gray-400 xl:col-span-2">
            No tags match the current search.
          </div>
        `;
        return;
      }

      elements.list.innerHTML = filtered.map(function renderTag(tag) {
        const usage = getUsage(tag.id);
        const color = normalizeColor(tag.color);
        const usageClass = usage > 0
          ? 'bg-emerald-500/10 text-emerald-700 dark:text-emerald-300'
          : 'bg-amber-500/10 text-amber-700 dark:text-amber-300';

        return `
          <article class="rounded-2xl border border-gray-200 p-5 transition-colors hover:border-indigo-300 hover:bg-indigo-50/30 dark:border-gray-800 dark:hover:border-indigo-500/40 dark:hover:bg-indigo-500/5">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <div class="flex items-center gap-3">
                  <span class="inline-flex h-3.5 w-3.5 rounded-full" style="background:${color};"></span>
                  <h3 class="text-lg font-semibold text-gray-900 dark:text-white">${AdminApp.escapeHtml(tag.name || 'Untitled tag')}</h3>
                </div>
                <div class="mt-2 text-sm text-gray-500 dark:text-gray-400">Slug: <code>${AdminApp.escapeHtml(tag.slug || '--')}</code></div>
                <div class="mt-1 text-sm text-gray-500 dark:text-gray-400">ID: <code>${AdminApp.escapeHtml(String(tag.id || ''))}</code></div>
              </div>
              <span class="pill ${usageClass}">${usage} post${usage === 1 ? '' : 's'}</span>
            </div>
            <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-gray-500 dark:text-gray-400">
              <span>Order ${Number(tag.order) || 0}</span>
              <span>${AdminApp.escapeHtml(color)}</span>
              <span>${tag.usageCount !== undefined ? `Seed counter ${Number(tag.usageCount) || 0}` : 'No seed counter'}</span>
            </div>
            <div class="mt-5 flex flex-wrap gap-3">
              <button type="button" class="rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800" data-edit-tag="${AdminApp.escapeHtml(String(tag.id))}">Edit</button>
              <button type="button" class="rounded-xl border border-rose-200 px-4 py-2 text-sm font-medium text-rose-700 transition-colors hover:bg-rose-50 dark:border-rose-900/50 dark:text-rose-300 dark:hover:bg-rose-500/10" data-delete-tag="${AdminApp.escapeHtml(String(tag.id))}">Delete</button>
            </div>
          </article>
        `;
      }).join('');
    }

    function closeModal() {
      elements.modal.classList.add('hidden');
      elements.modal.classList.remove('flex');
      state.editingId = '';
      state.slugTouched = false;
      elements.form.reset();
      elements.colorInput.value = '#6366f1';
      elements.orderInput.value = '';
      elements.deleteButton.classList.add('hidden');
      updatePreview();
    }

    function openModal(tagId) {
      state.editingId = String(tagId || '');
      state.slugTouched = false;

      const tag = state.tags.find(function findTag(item) {
        return String(item.id) === state.editingId;
      });

      elements.modalTitle.textContent = tag ? 'Edit Tag' : 'Create Tag';
      elements.nameInput.value = tag ? String(tag.name || '') : '';
      elements.slugInput.value = tag ? String(tag.slug || '') : '';
      elements.colorInput.value = normalizeColor(tag ? tag.color : '#6366f1');
      elements.orderInput.value = tag ? String(Number(tag.order) || 1) : String(sortTags(state.tags).length + 1);
      elements.deleteButton.classList.toggle('hidden', !tag);
      elements.modal.classList.remove('hidden');
      elements.modal.classList.add('flex');
      updatePreview();
      elements.nameInput.focus();
    }

    async function loadTags() {
      layout.setNotice('Loading tags...', 'info');
      try {
        const results = await Promise.all([
          AdminApp.requestJson('/api/data/tags'),
          AdminApp.requestJson('/api/data/posts'),
        ]);

        state.tags = Array.isArray(results[0]) ? results[0] : [];
        state.posts = Array.isArray(results[1]) ? results[1] : [];
        state.usageMap = buildUsageMap(state.posts);
        syncMetrics();
        renderTagList();
        layout.setNotice(`Loaded ${state.tags.length} tags.`, 'success');
      } catch (error) {
        layout.setNotice(`Failed to load tags: ${error.message}`, 'error');
      }
    }

    function validatePayload(name, slug, color) {
      if (!name) {
        throw new Error('Tag name is required.');
      }
      if (!slug) {
        throw new Error('Tag slug is required.');
      }
      const duplicated = state.tags.some(function checkDuplicate(tag) {
        return String(tag.slug || '').toLowerCase() === slug.toLowerCase()
          && String(tag.id) !== state.editingId;
      });
      if (duplicated) {
        throw new Error('Tag slug must be unique.');
      }
      return {
        name: name,
        slug: slug,
        color: normalizeColor(color),
      };
    }

    async function saveTag() {
      try {
        const name = String(elements.nameInput.value || '').trim();
        const slug = String(elements.slugInput.value || '').trim() || slugify(name);
        const color = elements.colorInput.value;
        const order = Number(elements.orderInput.value) || (sortTags(state.tags).length + 1);
        const base = validatePayload(name, slug, color);
        const current = state.tags.find(function findCurrent(tag) {
          return String(tag.id) === state.editingId;
        }) || {};
        const payload = {
          ...current,
          ...base,
          order,
          usageCount: state.editingId ? getUsage(state.editingId) : 0,
        };
        const requestOptions = state.editingId
          ? { method: 'PATCH', body: payload }
          : { method: 'POST', body: payload };
        const requestPath = state.editingId
          ? `/api/data/tags/${encodeURIComponent(state.editingId)}`
          : '/api/data/tags';

        layout.setNotice('Saving tag...', 'info');
        await AdminApp.requestJson(requestPath, requestOptions);
        closeModal();
        await loadTags();
        layout.setNotice('Tag saved.', 'success');
      } catch (error) {
        layout.setNotice(`Failed to save tag: ${error.message}`, 'error');
      }
    }

    async function deleteTag(tagId) {
      const id = String(tagId || '');
      const usage = getUsage(id);
      if (usage > 0) {
        layout.setNotice(`Tag is still used by ${usage} post(s) and cannot be deleted.`, 'error');
        return;
      }
      if (!window.confirm('Delete this tag?')) {
        return;
      }

      try {
        layout.setNotice('Deleting tag...', 'info');
        await AdminApp.requestJson(`/api/data/tags/${encodeURIComponent(id)}`, {
          method: 'DELETE',
        });
        if (state.editingId === id) {
          closeModal();
        }
        await loadTags();
        layout.setNotice('Tag deleted.', 'success');
      } catch (error) {
        layout.setNotice(`Failed to delete tag: ${error.message}`, 'error');
      }
    }

    document.getElementById('reload-tags-btn').addEventListener('click', function handleReload() {
      loadTags();
    });

    document.getElementById('create-tag-btn').addEventListener('click', function handleCreate() {
      openModal('');
    });

    elements.searchInput.addEventListener('input', function handleSearch(event) {
      state.search = event.target.value;
      renderTagList();
    });

    elements.nameInput.addEventListener('input', function handleNameInput() {
      if (!state.slugTouched) {
        elements.slugInput.value = slugify(elements.nameInput.value);
      }
      updatePreview();
    });

    elements.slugInput.addEventListener('input', function handleSlugInput() {
      state.slugTouched = true;
    });

    elements.colorInput.addEventListener('input', updatePreview);

    elements.closeModalButton.addEventListener('click', closeModal);

    elements.modal.addEventListener('click', function handleModalClick(event) {
      if (event.target === elements.modal) {
        closeModal();
      }
    });

    elements.form.addEventListener('submit', function handleFormSubmit(event) {
      event.preventDefault();
      saveTag();
    });

    elements.deleteButton.addEventListener('click', function handleDeleteFromModal() {
      if (state.editingId) {
        deleteTag(state.editingId);
      }
    });

    elements.list.addEventListener('click', function handleListClick(event) {
      const editButton = event.target.closest('[data-edit-tag]');
      if (editButton) {
        openModal(editButton.getAttribute('data-edit-tag'));
        return;
      }

      const deleteButton = event.target.closest('[data-delete-tag]');
      if (deleteButton) {
        deleteTag(deleteButton.getAttribute('data-delete-tag'));
      }
    });

    const unsubscribe = AdminApp.subscribeToDataChanges(function onDataChange() {
      loadTags();
    });

    window.addEventListener('beforeunload', function cleanup() {
      unsubscribe();
    });

    updatePreview();
    loadTags();
  </script>
</body>
</html>
