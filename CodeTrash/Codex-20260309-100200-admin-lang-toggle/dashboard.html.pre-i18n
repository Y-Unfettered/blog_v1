<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DevLog Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '#6366f1',
            dark: {
              bg: '#0a0a0a',
              surface: '#111111',
              border: '#1f1f1f',
            },
          },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/admin/admin-common.css">
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-[#0a0a0a] dark:text-gray-100">
  <div id="admin-app"></div>

  <script src="/admin/admin-common.js"></script>
  <script>
    if (!window.AdminApp || !AdminApp.requireAuth()) {
      throw new Error('Missing admin auth context.');
    }

    const layout = AdminApp.mountPage({
      active: 'dashboard',
      title: 'Dashboard',
      description: 'Review content volume, recent updates, category distribution, and current admin runtime information.',
      actions: [
        {
          id: 'create-post-btn',
          label: 'New Post',
          href: '/admin/editor',
          className: 'rounded-xl bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-lg shadow-indigo-500/20 transition-colors hover:bg-indigo-700',
        },
        {
          id: 'open-site-btn',
          label: 'Open Site',
          href: '/',
          external: true,
          className: 'rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800',
        },
      ],
    });

    layout.content.innerHTML = `
      <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <article class="admin-panel metric-card p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm text-gray-500 dark:text-gray-400">Posts</div>
              <div id="metric-total-posts" class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">--</div>
            </div>
            <div class="rounded-2xl bg-indigo-50 px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-indigo-600 dark:bg-indigo-500/10 dark:text-indigo-300">POSTS</div>
          </div>
          <div class="mt-4 text-sm text-gray-500 dark:text-gray-400">
            Published <span id="metric-published-posts" class="font-semibold text-gray-900 dark:text-white">--</span>
            / Drafts <span id="metric-draft-posts" class="font-semibold text-gray-900 dark:text-white">--</span>
          </div>
        </article>

        <article class="admin-panel metric-card p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm text-gray-500 dark:text-gray-400">Content Structure</div>
              <div id="metric-sections" class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">--</div>
            </div>
            <div class="rounded-2xl bg-emerald-50 px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-300">TREE</div>
          </div>
          <div class="mt-4 text-sm text-gray-500 dark:text-gray-400">
            Categories <span id="metric-categories" class="font-semibold text-gray-900 dark:text-white">--</span>
            / Tags <span id="metric-tags" class="font-semibold text-gray-900 dark:text-white">--</span>
          </div>
        </article>

        <article class="admin-panel metric-card p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm text-gray-500 dark:text-gray-400">Navigation</div>
              <div id="metric-nav-visible" class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">--</div>
            </div>
            <div class="rounded-2xl bg-amber-50 px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-amber-600 dark:bg-amber-500/10 dark:text-amber-300">NAV</div>
          </div>
          <div class="mt-4 text-sm text-gray-500 dark:text-gray-400">
            Visible / Total <span id="metric-nav-total" class="font-semibold text-gray-900 dark:text-white">--</span>
          </div>
        </article>

        <article class="admin-panel metric-card p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="text-sm text-gray-500 dark:text-gray-400">Pinned Posts</div>
              <div id="metric-pinned-posts" class="mt-2 text-3xl font-bold text-gray-900 dark:text-white">--</div>
            </div>
            <div class="rounded-2xl bg-rose-50 px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-rose-600 dark:bg-rose-500/10 dark:text-rose-300">PIN</div>
          </div>
          <div class="mt-4 text-sm text-gray-500 dark:text-gray-400">
            Generated at <span id="dashboard-generated-at" class="font-semibold text-gray-900 dark:text-white">--</span>
          </div>
        </article>
      </section>

      <section class="mt-6 grid gap-6 xl:grid-cols-[minmax(0,1.5fr)_minmax(320px,0.9fr)]">
        <article class="admin-panel p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="admin-kicker text-gray-500 dark:text-gray-400">Recent Posts</div>
              <h2 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">Latest Updates</h2>
            </div>
            <a href="/admin/posts" class="text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-300 dark:hover:text-indigo-200">Open Posts</a>
          </div>
          <div id="recent-posts-list" class="mt-5 space-y-3"></div>
        </article>

        <article class="admin-panel p-6">
          <div class="admin-kicker text-gray-500 dark:text-gray-400">System</div>
          <h2 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">Runtime</h2>
          <div class="mt-5 space-y-4">
            <div class="rounded-2xl bg-gray-50 px-4 py-3 dark:bg-gray-800/70">
              <div class="text-sm text-gray-500 dark:text-gray-400">Node Version</div>
              <div id="system-node-version" class="mt-1 text-base font-semibold text-gray-900 dark:text-white">--</div>
            </div>
            <div class="rounded-2xl bg-gray-50 px-4 py-3 dark:bg-gray-800/70">
              <div class="text-sm text-gray-500 dark:text-gray-400">Uptime</div>
              <div id="system-uptime" class="mt-1 text-base font-semibold text-gray-900 dark:text-white">--</div>
            </div>
            <div class="rounded-2xl bg-gray-50 px-4 py-3 dark:bg-gray-800/70">
              <div class="text-sm text-gray-500 dark:text-gray-400">Data Directory</div>
              <div id="system-data-dir" class="mt-1 break-all text-sm font-semibold text-gray-900 dark:text-white">--</div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="rounded-2xl bg-gray-50 px-4 py-3 dark:bg-gray-800/70">
                <div class="text-sm text-gray-500 dark:text-gray-400">RSS Memory</div>
                <div id="system-rss" class="mt-1 text-base font-semibold text-gray-900 dark:text-white">--</div>
              </div>
              <div class="rounded-2xl bg-gray-50 px-4 py-3 dark:bg-gray-800/70">
                <div class="text-sm text-gray-500 dark:text-gray-400">Heap Used</div>
                <div id="system-heap" class="mt-1 text-base font-semibold text-gray-900 dark:text-white">--</div>
              </div>
            </div>
          </div>
        </article>
      </section>

      <section class="mt-6 grid gap-6 xl:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)]">
        <article class="admin-panel p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <div class="admin-kicker text-gray-500 dark:text-gray-400">Weekly Activity</div>
              <h2 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">Last 7 Days</h2>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Counted from post create and update timestamps.</div>
          </div>
          <div id="weekly-activity" class="mt-6 flex h-56 items-end gap-3"></div>
        </article>

        <article class="admin-panel p-6">
          <div class="admin-kicker text-gray-500 dark:text-gray-400">Top Categories</div>
          <h2 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">Category Distribution</h2>
          <div id="top-categories-list" class="mt-5 space-y-3"></div>
          <div class="mt-6 rounded-2xl bg-gray-50 px-4 py-4 dark:bg-gray-800/70">
            <div class="text-sm text-gray-500 dark:text-gray-400">Current Site Profile</div>
            <div id="site-name" class="mt-2 text-base font-semibold text-gray-900 dark:text-white">--</div>
            <div id="site-author" class="mt-1 text-sm text-gray-500 dark:text-gray-400">--</div>
            <div class="mt-3 text-sm text-gray-500 dark:text-gray-400">Markdown Theme: <span id="site-markdown-theme" class="font-semibold text-gray-900 dark:text-white">--</span></div>
          </div>
        </article>
      </section>
    `;

    function renderMetrics(stats, generatedAt) {
      document.getElementById('metric-total-posts').textContent = stats.totalPosts;
      document.getElementById('metric-published-posts').textContent = stats.publishedPosts;
      document.getElementById('metric-draft-posts').textContent = stats.draftPosts;
      document.getElementById('metric-sections').textContent = stats.totalSections;
      document.getElementById('metric-categories').textContent = stats.totalCategories;
      document.getElementById('metric-tags').textContent = stats.totalTags;
      document.getElementById('metric-nav-visible').textContent = stats.visibleNavItems;
      document.getElementById('metric-nav-total').textContent = stats.visibleNavItems + ' / ' + stats.totalNavItems;
      document.getElementById('metric-pinned-posts').textContent = stats.pinnedPosts;
      document.getElementById('dashboard-generated-at').textContent = AdminApp.formatDateTime(generatedAt);
    }

    function renderRecentPosts(posts) {
      const container = document.getElementById('recent-posts-list');
      if (!posts.length) {
        container.innerHTML = '<div class="rounded-2xl bg-gray-50 px-4 py-5 text-sm text-gray-500 dark:bg-gray-800/70 dark:text-gray-400">No recent posts available.</div>';
        return;
      }

      container.innerHTML = posts.map(function renderPost(post) {
        const statusClass = post.status === 'published' ? 'status-published' : 'status-draft';
        const statusText = post.status === 'published' ? 'Published' : 'Draft';
        const pinnedText = post.pinned ? '<span class="pill bg-indigo-500/10 text-indigo-600 dark:text-indigo-300">Pinned</span>' : '';
        const categories = post.categories.length ? post.categories.join(' / ') : 'No category';
        return `
          <a href="/admin/editor?id=${encodeURIComponent(post.id)}" class="block rounded-2xl border border-gray-200 px-4 py-4 transition-colors hover:border-indigo-300 hover:bg-indigo-50/40 dark:border-gray-800 dark:hover:border-indigo-500/40 dark:hover:bg-indigo-500/5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <div class="text-base font-semibold text-gray-900 dark:text-white">${AdminApp.escapeHtml(post.title)}</div>
                <div class="mt-1 text-sm text-gray-500 dark:text-gray-400">${AdminApp.escapeHtml(categories)}</div>
              </div>
              <div class="flex items-center gap-2">
                ${pinnedText}
                <span class="pill ${statusClass}">${statusText}</span>
              </div>
            </div>
            <div class="mt-3 text-xs text-gray-500 dark:text-gray-400">Updated: ${AdminApp.formatDateTime(post.updatedAt)}</div>
          </a>
        `;
      }).join('');
    }

    function renderWeeklyActivity(items) {
      const container = document.getElementById('weekly-activity');
      if (!items.length) {
        container.innerHTML = '<div class="text-sm text-gray-500 dark:text-gray-400">No activity data available.</div>';
        return;
      }

      const maxCount = Math.max.apply(null, items.map(function pickCount(item) { return item.count; }).concat([1]));
      container.innerHTML = items.map(function renderItem(item) {
        const height = Math.max(12, Math.round((item.count / maxCount) * 180));
        const label = item.date.slice(5).replace('-', '/');
        return `
          <div class="flex flex-1 flex-col items-center gap-3">
            <div class="w-full rounded-t-2xl bg-gradient-to-t from-indigo-600 to-indigo-400" style="height: ${height}px"></div>
            <div class="text-sm font-semibold text-gray-900 dark:text-white">${item.count}</div>
            <div class="text-xs text-gray-500 dark:text-gray-400">${label}</div>
          </div>
        `;
      }).join('');
    }

    function renderTopCategories(items) {
      const container = document.getElementById('top-categories-list');
      if (!items.length) {
        container.innerHTML = '<div class="rounded-2xl bg-gray-50 px-4 py-5 text-sm text-gray-500 dark:bg-gray-800/70 dark:text-gray-400">No category stats available.</div>';
        return;
      }

      container.innerHTML = items.map(function renderCategory(item, index) {
        return `
          <div class="flex items-center justify-between rounded-2xl bg-gray-50 px-4 py-3 dark:bg-gray-800/70">
            <div class="flex items-center gap-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-indigo-500/10 text-sm font-semibold text-indigo-600 dark:text-indigo-300">${index + 1}</div>
              <div>
                <div class="text-sm font-semibold text-gray-900 dark:text-white">${AdminApp.escapeHtml(item.name || 'Unnamed category')}</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Posts: ${item.count}</div>
              </div>
            </div>
            <div class="text-sm font-semibold text-gray-900 dark:text-white">${item.count}</div>
          </div>
        `;
      }).join('');
    }

    function renderSystem(system, site) {
      document.getElementById('system-node-version').textContent = system.nodeVersion || '--';
      document.getElementById('system-uptime').textContent = AdminApp.formatDuration(system.uptimeSeconds);
      document.getElementById('system-data-dir').textContent = system.dataDir || '--';
      document.getElementById('system-rss').textContent = (system.rssMb || 0) + ' MB';
      document.getElementById('system-heap').textContent = (system.heapUsedMb || 0) + ' MB';
      document.getElementById('site-name').textContent = site.siteName || 'Site name not configured';
      document.getElementById('site-author').textContent = site.author || 'Author not configured';
      document.getElementById('site-markdown-theme').textContent = site.markdownTheme || 'default';
    }

    async function loadDashboard() {
      layout.setNotice('Loading dashboard data...', 'info');
      try {
        const payload = await AdminApp.requestJson('/api/data/dashboard');
        renderMetrics(payload.stats, payload.generatedAt);
        renderRecentPosts(payload.recentPosts || []);
        renderWeeklyActivity(payload.weeklyActivity || []);
        renderTopCategories(payload.topCategories || []);
        renderSystem(payload.system || {}, payload.site || {});
        layout.setNotice('Dashboard synchronized at ' + AdminApp.formatDateTime(payload.generatedAt) + '.', 'success');
      } catch (error) {
        layout.setNotice('Failed to load dashboard: ' + error.message, 'error');
      }
    }

    const unsubscribe = AdminApp.subscribeToDataChanges(function onDataChange() {
      loadDashboard();
    });

    window.addEventListener('beforeunload', function cleanup() {
      unsubscribe();
    });

    loadDashboard();
  </script>
</body>
</html>
