  <script>
    // ========== ńŞ╗ÚóśňłçŠŹó ==========
    let currentTheme = localStorage.getItem('theme') || 'dark';
    
    function initTheme() {
      setTheme(currentTheme);
    }
    
    function toggleTheme() {
      currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
      setTheme(currentTheme);
    }
    
    function setTheme(theme) {
      currentTheme = theme;
      localStorage.setItem('theme', theme);
      const html = document.documentElement;
      const icon = document.getElementById('themeIcon');
      
      html.classList.remove('light', 'dark');
      html.classList.add(theme);
      
      if (theme === 'dark') {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>';
      } else {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>';
      }
    }
    
    // ňłŁňžőňîľńŞ╗Úó?    initTheme();

    // ========== Šáçšşżš«íšÉćňŐčŔâŻ ==========
    const token = localStorage.getItem('token');
    if (!token) {
      window.location.href = '/admin';
    }

    let tags = [];
    let posts = [];
    let editingId = '';
    let slugTouched = false;

    const searchInput = document.getElementById('searchInput');
    const tagCloudEl = document.getElementById('tagCloud');
    const editorModal = document.getElementById('editorModal');
    const editorTitle = document.getElementById('editorTitle');
    const tagNameInput = document.getElementById('tagName');
    const tagSlugInput = document.getElementById('tagSlug');
    const tagColorInput = document.getElementById('tagColor');

    function escapeHtml(input) {
      return String(input || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function slugify(input) {
      return String(input || '')
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    function nextId(list, prefix) {
      const nums = list
        .map((item) => Number(item && item.id))
        .filter((n) => Number.isFinite(n));
      if (nums.length) {
        return String(Math.max(...nums) + 1);
      }
      return `${prefix}-${Date.now()}`;
    }

    function resolvePostTags(post) {
      if (Array.isArray(post.tags)) return post.tags;
      if (Array.isArray(post.tagIds)) return post.tagIds;
      return [];
    }

    function countUsage(tagId) {
      return posts.reduce((total, post) => {
        return resolvePostTags(post).includes(tagId) ? total + 1 : total;
      }, 0);
    }

    async function fetchData(type) {
      const response = await fetch(`/api/data/${type}`, {
        headers: {
          Authorization: `Bearer ${token}`,
        },
      });
      if (response.status === 401) {
        logout();
        return [];
      }
      if (!response.ok) {
        throw new Error(`ňŐáŔŻŻ ${type} ňĄ▒Ŕ┤ą`);
      }
      return await response.json();
    }

    async function saveData(type, data) {
      const response = await fetch(`/api/data/${type}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify(data),
      });
      if (!response.ok) {
        throw new Error(`ń┐Łňşś ${type} ňĄ▒Ŕ┤ą`);
      }
    }

    function renderTagCloud() {
      if (!tags.length) {
        tagCloudEl.innerHTML = '<span class="text-gray-500 dark:text-gray-400">ŠÜéŠŚáŠáçšşż</span>';
        return;
      }

      const maxUsage = Math.max(...tags.map(t => countUsage(t.id)), 1);
      const sortedTags = tags.slice().sort((a, b) => countUsage(b.id) - countUsage(a.id));

      tagCloudEl.innerHTML = sortedTags.map(tag => {
        const usage = countUsage(tag.id);
        const size = 0.875 + (usage / maxUsage) * 0.625;
        const color = tag.color || '#6366f1';
        const opacity = 0.4 + (usage / maxUsage) * 0.6;
        
        return `
          <span 
            class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full transition-all hover:scale-110 cursor-pointer"
            style="font-size: ${size}rem; background: ${color}20; color: ${color}; border: 1px solid ${color}40"
            title="${usage} š»çŠľçšź?
          >
            <span style="opacity: ${opacity}">#</span>
            ${escapeHtml(tag.name)}
            <span class="text-xs opacity-60">(${usage})</span>
          </span>
        `;
      }).join('');
    }

    function renderTable() {
      const keyword = String(searchInput.value || '').trim().toLowerCase();
      const tbody = document.getElementById('tableBody');
      const list = tags
        .slice()
        .filter((item) => {
          if (!keyword) return true;
          const name = String(item.name || '').toLowerCase();
          const slug = String(item.slug || '').toLowerCase();
          return name.includes(keyword) || slug.includes(keyword);
        })
        .sort((a, b) => String(a.name || '').localeCompare(String(b.name || '')));

      if (!list.length) {
        tbody.innerHTML = `
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">ŠÜéŠŚáŠáçšşżŠĽ░ŠŹ«</td>
          </tr>
        `;
        return;
      }

      tbody.innerHTML = list.map((item) => {
        const usage = countUsage(item.id);
        const color = item.color || '#6366f1';
        return `
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors">
            <td class="px-6 py-4 text-gray-900 dark:text-white font-medium">${escapeHtml(item.name)}</td>
            <td class="px-6 py-4 text-gray-500 dark:text-gray-400">${escapeHtml(item.slug)}</td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center gap-2 text-gray-700 dark:text-gray-300">
                <i class="w-3 h-3 rounded-full" style="background:${escapeHtml(color)}"></i>
                ${escapeHtml(color)}
              </span>
            </td>
            <td class="px-6 py-4 text-gray-700 dark:text-gray-300">${usage}</td>
            <td class="px-6 py-4 text-right space-x-2">
              <button onclick="openEditor('${escapeHtml(String(item.id))}')" class="px-3 py-1.5 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg transition-colors">š╝ľŔżĹ</button>
              <button onclick="deleteTag('${escapeHtml(String(item.id))}')" class="px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors">ňłáÚÖĄ</button>
            </td>
          </tr>
        `;
      }).join('');
    }

    function openEditor(id) {
      editingId = id || '';
      slugTouched = false;
      const item = tags.find((tag) => String(tag.id) === String(editingId));

      editorTitle.textContent = item ? 'š╝ľŔżĹŠáçšşż' : 'Šľ░ňó×Šáçšşż';
      tagNameInput.value = item ? String(item.name || '') : '';
      tagSlugInput.value = item ? String(item.slug || '') : '';
      tagColorInput.value = item ? String(item.color || '#6366f1') : '#6366f1';
      editorModal.classList.remove('hidden');
      editorModal.classList.add('flex');
      tagNameInput.focus();
    }

    function closeEditor() {
      editorModal.classList.add('hidden');
      editorModal.classList.remove('flex');
      editingId = '';
    }

    async function saveTag() {
      const name = String(tagNameInput.value || '').trim();
      const slug = String(tagSlugInput.value || '').trim() || slugify(name);
      const color = String(tagColorInput.value || '#6366f1').trim() || '#6366f1';
      
      if (!name) {
        alert('ŠáçšşżňÉŹšž░ńŞŹŔâŻńŞ║šę║');
        return;
      }
      if (!slug) {
        alert('Slug ńŞŹŔâŻńŞ║šę║');
        return;
      }

      const duplicated = tags.some((item) =>
        String(item.slug || '').toLowerCase() === slug.toLowerCase()
        && String(item.id) !== String(editingId)
      );
      if (duplicated) {
        alert('Slug ňĚ▓ňşśňťĘ´╝îŔ»ĚŠŤ┤ŠŹ?);
        return;
      }

      if (editingId) {
        const index = tags.findIndex((item) => String(item.id) === String(editingId));
        if (index >= 0) {
          tags[index] = {
            ...tags[index],
            name,
            slug,
            color,
          };
        }
      } else {
        tags.push({
          id: nextId(tags, 'tag'),
          name,
          slug,
          color,
        });
      }

      try {
        await saveData('tags', tags);
        closeEditor();
        renderTable();
        renderTagCloud();
      } catch (error) {
        console.error(error);
        alert('ń┐ŁňşśŠáçšşżňĄ▒Ŕ┤ą');
      }
    }

    async function deleteTag(id) {
      const usage = countUsage(id);
      if (usage > 0) {
        alert(`Ŕ»ąŠáçšşżňĚ▓Ŕó?${usage} š»çŠľçšźáńŻ┐šöĘ´╝îńŞŹŔâŻňłáÚÖĄ`);
        return;
      }
      if (!confirm('ší«ň«ÜňłáÚÖĄŔ»ąŠáçšşżňÉŚ´╝?)) return;

      tags = tags.filter((item) => String(item.id) !== String(id));
      try {
        await saveData('tags', tags);
        renderTable();
      } catch (error) {
        console.error(error);
        alert('ňłáÚÖĄŠáçšşżňĄ▒Ŕ┤ą');
      }
    }

    async function initPage() {
      try {
        const [tagData, postData] = await Promise.all([
          fetchData('tags'),
          fetchData('posts'),
        ]);
        tags = Array.isArray(tagData) ? tagData : [];
        posts = Array.isArray(postData) ? postData : [];
        renderTable();
        renderTagCloud();
      } catch (error) {
        console.error(error);
        document.getElementById('tableBody').innerHTML = `
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-red-500 dark:text-red-400">ňŐáŔŻŻŠĽ░ŠŹ«ňĄ▒Ŕ┤ą´╝îŔ»ĚňłĚŠľ░ÚçŹŔ»Ľ</td>
          </tr>
        `;
      }
    }

    tagNameInput.addEventListener('input', () => {
      if (slugTouched) return;
      tagSlugInput.value = slugify(tagNameInput.value);
    });
    tagSlugInput.addEventListener('input', () => {
      slugTouched = true;
    });

    function goBack() {
