(function bootstrapAdminCommon() {
  const STORAGE_THEME_KEY = 'theme';
  const STORAGE_TOKEN_KEY = 'token';

  const NAV_ITEMS = [
    { key: 'dashboard', label: '概览', href: '/admin/dashboard' },
    { key: 'posts', label: '文章管理', href: '/admin/posts' },
    { key: 'sections', label: '栏目管理', href: '/admin/sections' },
    { key: 'categories', label: '分类管理', href: '/admin/categories' },
    { key: 'tags', label: '标签管理', href: '/admin/tags' },
    { key: 'settings', label: '系统设置', href: '/admin/settings' },
  ];

  function getToken() {
    return String(localStorage.getItem(STORAGE_TOKEN_KEY) || '').trim();
  }

  function logout() {
    localStorage.removeItem(STORAGE_TOKEN_KEY);
    window.location.href = '/admin';
  }

  function requireAuth() {
    if (!getToken()) {
      logout();
      return false;
    }
    return true;
  }

  function setTheme(theme) {
    const nextTheme = theme === 'light' ? 'light' : 'dark';
    localStorage.setItem(STORAGE_THEME_KEY, nextTheme);
    document.documentElement.classList.remove('light', 'dark');
    document.documentElement.classList.add(nextTheme);

    const icon = document.getElementById('admin-theme-icon');
    if (!icon) return;

    if (nextTheme === 'dark') {
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>';
    } else {
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>';
    }
  }

  function initTheme() {
    const theme = localStorage.getItem(STORAGE_THEME_KEY) || 'dark';
    setTheme(theme);
  }

  function toggleTheme() {
    const current = localStorage.getItem(STORAGE_THEME_KEY) || 'dark';
    setTheme(current === 'dark' ? 'light' : 'dark');
  }

  async function requestJson(url, options = {}) {
    const {
      method = 'GET',
      body,
      headers = {},
      auth = true,
    } = options;

    const requestHeaders = { ...headers };
    if (auth) {
      const token = getToken();
      if (!token) {
        logout();
        throw new Error('登录已失效');
      }
      requestHeaders.Authorization = `Bearer ${token}`;
    }

    let payloadBody = body;
    if (body !== undefined && body !== null && typeof body === 'object' && !(body instanceof FormData)) {
      requestHeaders['Content-Type'] = requestHeaders['Content-Type'] || 'application/json';
      payloadBody = JSON.stringify(body);
    }

    const response = await fetch(url, {
      method,
      headers: requestHeaders,
      body: payloadBody,
    });

    if (response.status === 401) {
      logout();
      throw new Error('登录已失效');
    }

    const text = await response.text();
    const data = text ? JSON.parse(text) : null;

    if (!response.ok) {
      throw new Error((data && (data.message || data.error)) || `请求失败 (${response.status})`);
    }

    return data;
  }

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatDateTime(value) {
    if (!value) return '--';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '--';
    return date.toLocaleString('zh-CN', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
    });
  }

  function formatDuration(seconds) {
    const total = Math.max(0, Number(seconds) || 0);
    const hours = Math.floor(total / 3600);
    const minutes = Math.floor((total % 3600) / 60);
    if (hours > 0) {
      return `${hours} 小时 ${minutes} 分钟`;
    }
    return `${minutes} 分钟`;
  }

  function subscribeToDataChanges(callback) {
    if (typeof EventSource === 'undefined') {
      return function noop() {};
    }

    const source = new EventSource('/api/events');
    source.addEventListener('data-change', callback);
    return function unsubscribe() {
      source.close();
    };
  }

  function renderActions(actions) {
    return actions.map((action) => {
      if (action.href) {
        return `
          <a
            href="${escapeHtml(action.href)}"
            ${action.external ? 'target="_blank" rel="noreferrer"' : ''}
            class="${escapeHtml(action.className || '')}"
            id="${escapeHtml(action.id || '')}"
          >${escapeHtml(action.label)}</a>
        `;
      }

      return `
        <button
          type="button"
          class="${escapeHtml(action.className || '')}"
          id="${escapeHtml(action.id || '')}"
        >${escapeHtml(action.label)}</button>
      `;
    }).join('');
  }

  function renderSidebar(activeKey) {
    return NAV_ITEMS.map((item) => `
      <a href="${item.href}" class="sidebar-item px-6 py-3 flex items-center gap-3 ${item.key === activeKey ? 'active' : ''}">
        <span class="font-medium">${item.label}</span>
      </a>
    `).join('');
  }

  function mountPage(options) {
    const {
      active = '',
      title = '',
      description = '',
      actions = [],
    } = options || {};

    const root = document.getElementById('admin-app');
    if (!root) {
      throw new Error('Missing #admin-app container.');
    }

    root.innerHTML = `
      <header class="sticky top-0 z-50 border-b border-gray-200 bg-white dark:border-[#1f1f1f] dark:bg-[#111111]">
        <div class="mx-auto flex h-16 max-w-[1600px] items-center justify-between px-6">
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-indigo-600 text-white shadow-lg shadow-indigo-500/20">DL</div>
            <div>
              <div class="text-sm font-semibold text-gray-900 dark:text-white">DevLog 管理后台</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">统一管理内容、导航与站点资料</div>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <button id="admin-theme-toggle" type="button" class="rounded-xl border border-gray-200 px-3 py-2 text-sm text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800">
              <svg id="admin-theme-icon" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"></svg>
            </button>
            <button id="admin-logout" type="button" class="rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800">
              退出登录
            </button>
          </div>
        </div>
      </header>

      <div class="mx-auto flex max-w-[1600px]">
        <aside class="sticky top-16 hidden h-[calc(100vh-64px)] w-64 shrink-0 overflow-y-auto border-r border-gray-200 bg-white dark:border-[#1f1f1f] dark:bg-[#111111] lg:block">
          <nav class="py-4">${renderSidebar(active)}</nav>
        </aside>
        <main class="min-h-[calc(100vh-64px)] flex-1 bg-gray-50 px-4 py-6 dark:bg-[#0a0a0a] sm:px-6">
          <section class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <div class="admin-kicker text-gray-500 dark:text-gray-400">${escapeHtml(active)}</div>
              <h1 class="mt-1 text-2xl font-bold text-gray-900 dark:text-white">${escapeHtml(title)}</h1>
              <p class="mt-2 max-w-3xl text-sm text-gray-500 dark:text-gray-400">${escapeHtml(description)}</p>
            </div>
            <div class="flex flex-wrap gap-3">${renderActions(actions)}</div>
          </section>
          <div id="admin-notice" class="notice"></div>
          <div id="admin-page-content"></div>
        </main>
      </div>
    `;

    document.getElementById('admin-theme-toggle').addEventListener('click', toggleTheme);
    document.getElementById('admin-logout').addEventListener('click', logout);
    initTheme();

    const notice = document.getElementById('admin-notice');
    return {
      content: document.getElementById('admin-page-content'),
      setNotice(message, type = 'info') {
        if (!message) {
          notice.className = 'notice';
          notice.textContent = '';
          return;
        }
        notice.className = `notice show notice-${type}`;
        notice.textContent = message;
      },
    };
  }

  window.AdminApp = {
    escapeHtml,
    formatDateTime,
    formatDuration,
    getToken,
    initTheme,
    logout,
    mountPage,
    requestJson,
    requireAuth,
    setTheme,
    subscribeToDataChanges,
    toggleTheme,
  };
})();
