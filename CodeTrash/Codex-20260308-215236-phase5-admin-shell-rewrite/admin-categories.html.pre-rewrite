<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>后台管理 - 分类管理</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '#6366f1',
            dark: {
              bg: '#0a0a0a',
              surface: '#111111',
              border: '#1f1f1f',
            },
          },
        },
      },
    };
  </script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    .sidebar-item { transition: all 0.2s ease; border-right: 2px solid transparent; }
    .sidebar-item:hover { background: rgba(99, 102, 241, 0.08); }
    .sidebar-item.active { background: rgba(99, 102, 241, 0.12); border-right-color: #6366f1; color: #6366f1; }
    .dark .sidebar-item:hover { background: rgba(99, 102, 241, 0.06); }
    .dark .sidebar-item.active { background: rgba(99, 102, 241, 0.1); border-right-color: #818cf8; color: #818cf8; }
    .category-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .category-card:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12); }
    .dark .category-card:hover { box-shadow: 0 12px 32px rgba(0, 0, 0, 0.32); }
  </style>
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-dark-bg dark:text-gray-100 transition-colors duration-200">
  <header class="sticky top-0 z-50 bg-white dark:bg-dark-surface border-b border-gray-200 dark:border-dark-border">
    <div class="flex items-center justify-between px-6 h-16">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center shadow-lg shadow-indigo-500/20">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
          </svg>
        </div>
        <h1 class="text-xl font-bold text-gray-900 dark:text-white">DevLog 后台管理</h1>
      </div>
      <div class="flex items-center gap-4">
        <button onclick="toggleTheme()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors" title="切换主题">
          <svg id="themeIcon" class="w-5 h-5 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
        </button>
        <button onclick="goBack()" class="flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-colors text-sm font-medium text-gray-700 dark:text-gray-300">
          返回
        </button>
        <button onclick="logout()" class="flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-colors text-sm font-medium text-gray-700 dark:text-gray-300">
          退出
        </button>
      </div>
    </div>
  </header>

  <div class="flex min-h-[calc(100vh-64px)]">
    <aside class="w-64 bg-white dark:bg-dark-surface border-r border-gray-200 dark:border-dark-border sticky top-16 h-[calc(100vh-64px)] overflow-y-auto flex-shrink-0">
      <nav class="py-4">
        <a href="/admin/dashboard" class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3">
          <span class="font-medium">概览</span>
        </a>
        <a href="/admin/posts" class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3">
          <span class="font-medium">文章管理</span>
        </a>
        <a href="/admin/sections" class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3">
          <span class="font-medium">栏目管理</span>
        </a>
        <div class="sidebar-item active px-6 py-3 cursor-pointer flex items-center gap-3">
          <span class="font-medium">分类管理</span>
        </div>
        <a href="/admin/tags" class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3">
          <span class="font-medium">标签管理</span>
        </a>
        <a href="/admin/settings" class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3">
          <span class="font-medium">系统设置</span>
        </a>
      </nav>
    </aside>

    <main class="flex-1 p-6 overflow-y-auto">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">分类管理</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">统一使用 `/api/data/categories`，并按文章数据实时统计分类使用量。</p>
        </div>
        <button onclick="openCreateModal()" class="flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl transition-colors font-medium shadow-lg shadow-indigo-500/20">
          新建分类
        </button>
      </div>

      <div class="bg-white dark:bg-dark-surface border border-gray-200 dark:border-dark-border rounded-xl p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4" id="categoryList"></div>
      </div>
    </main>
  </div>

  <div id="categoryModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center">
    <div class="bg-white dark:bg-dark-surface rounded-2xl p-6 w-full max-w-md mx-4 border border-gray-200 dark:border-dark-border shadow-2xl">
      <h3 id="modalTitle" class="text-lg font-bold text-gray-900 dark:text-white mb-4">新建分类</h3>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">分类名称</label>
          <input type="text" id="categoryName" class="w-full px-4 py-2.5 bg-gray-50 dark:bg-dark-surface border border-gray-200 dark:border-dark-border rounded-xl text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="输入分类名称">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">分类描述</label>
          <textarea id="categoryDesc" rows="3" class="w-full px-4 py-2.5 bg-gray-50 dark:bg-dark-surface border border-gray-200 dark:border-dark-border rounded-xl text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500" placeholder="简要描述这个分类"></textarea>
        </div>
        <div class="flex gap-3 pt-4">
          <button onclick="closeModal()" class="flex-1 px-4 py-2.5 bg-gray-100 dark:bg-dark-surface hover:bg-gray-200 dark:hover:bg-gray-700 rounded-xl transition-colors font-medium text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-dark-border">取消</button>
          <button onclick="saveCategory()" class="flex-1 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 rounded-xl transition-colors font-medium text-white shadow-lg shadow-indigo-500/20">保存</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    let currentTheme = localStorage.getItem('theme') || 'dark';
    let editingCategoryId = null;
    let categories = [];
    let categoryUsage = new Map();

    function initTheme() {
      setTheme(currentTheme);
    }

    function toggleTheme() {
      currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
      setTheme(currentTheme);
    }

    function setTheme(theme) {
      currentTheme = theme;
      localStorage.setItem('theme', theme);
      const html = document.documentElement;
      const icon = document.getElementById('themeIcon');

      html.classList.remove('light', 'dark');
      html.classList.add(theme);

      if (theme === 'dark') {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>';
      } else {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>';
      }
    }

    function getToken() {
      const token = localStorage.getItem('token');
      if (!token) {
        logout();
        return '';
      }
      return token;
    }

    async function fetchAdminData(pathname) {
      const response = await fetch(pathname, {
        headers: {
          Authorization: `Bearer ${getToken()}`,
        },
      });

      if (response.status === 401) {
        logout();
        return null;
      }

      if (!response.ok) {
        throw new Error(`Request failed: ${pathname}`);
      }

      return response.json();
    }

    function createSlug(value) {
      const slug = String(value || '')
        .trim()
        .toLowerCase()
        .normalize('NFKD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
      return slug || `category-${Date.now()}`;
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function resolvePostCategories(post) {
      if (Array.isArray(post.categories)) return post.categories;
      if (Array.isArray(post.categoryIds)) return post.categoryIds;
      if (post.categoryId) return [String(post.categoryId)];
      return [];
    }

    function buildCategoryUsage(posts) {
      const usage = new Map();
      (Array.isArray(posts) ? posts : []).forEach((post) => {
        resolvePostCategories(post).forEach((categoryId) => {
          const key = String(categoryId);
          usage.set(key, (usage.get(key) || 0) + 1);
        });
      });
      return usage;
    }

    async function loadCategories() {
      try {
        const [categoryData, postData] = await Promise.all([
          fetchAdminData('/api/data/categories'),
          fetchAdminData('/api/data/posts'),
        ]);

        categories = Array.isArray(categoryData) ? categoryData : [];
        categoryUsage = buildCategoryUsage(postData);
        renderCategories();
      } catch (error) {
        console.error('Load categories failed:', error);
        alert('加载分类失败。');
      }
    }

    function renderCategories() {
      const container = document.getElementById('categoryList');
      if (categories.length === 0) {
        container.innerHTML = '<div class="col-span-full text-center py-12 text-gray-500 dark:text-gray-400">暂无分类，点击右上角创建。</div>';
        return;
      }

      container.innerHTML = categories.map((cat) => {
        const count = categoryUsage.get(String(cat.id)) || 0;
        return `
          <div class="category-card bg-white dark:bg-dark-surface border border-gray-200 dark:border-dark-border rounded-xl p-5 cursor-pointer transition-colors duration-200" onclick="editCategory('${escapeHtml(cat.id)}')">
            <div class="flex items-start justify-between mb-3">
              <div class="w-10 h-10 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
                </svg>
              </div>
              <span class="text-xs text-gray-500 dark:text-gray-400">${count} 篇文章</span>
            </div>
            <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">${escapeHtml(cat.name || '未命名分类')}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2">${escapeHtml(cat.description || '暂无描述')}</p>
          </div>
        `;
      }).join('');
    }

    function openCreateModal() {
      editingCategoryId = null;
      document.getElementById('modalTitle').textContent = '新建分类';
      document.getElementById('categoryName').value = '';
      document.getElementById('categoryDesc').value = '';
      document.getElementById('categoryModal').classList.remove('hidden');
    }

    function editCategory(id) {
      editingCategoryId = id;
      const category = categories.find((item) => String(item.id) === String(id));
      if (!category) return;

      document.getElementById('modalTitle').textContent = '编辑分类';
      document.getElementById('categoryName').value = category.name || '';
      document.getElementById('categoryDesc').value = category.description || '';
      document.getElementById('categoryModal').classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('categoryModal').classList.add('hidden');
    }

    async function saveCategory() {
      const name = document.getElementById('categoryName').value.trim();
      const description = document.getElementById('categoryDesc').value.trim();

      if (!name) {
        alert('请输入分类名称。');
        return;
      }

      const existingCategory = categories.find((item) => String(item.id) === String(editingCategoryId));
      const payload = editingCategoryId
        ? {
            ...existingCategory,
            name,
            description,
          }
        : {
            name,
            description,
            slug: createSlug(name),
            order: categories.reduce((max, item) => Math.max(max, Number(item.order) || 0), 0) + 1,
          };

      const url = editingCategoryId ? `/api/data/categories/${editingCategoryId}` : '/api/data/categories';
      const method = editingCategoryId ? 'PATCH' : 'POST';

      try {
        const response = await fetch(url, {
          method,
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${getToken()}`,
          },
          body: JSON.stringify(payload),
        });

        if (response.status === 401) {
          logout();
          return;
        }

        if (!response.ok) {
          throw new Error('Save failed');
        }

        closeModal();
        await loadCategories();
      } catch (error) {
        console.error('Save category failed:', error);
        alert('保存分类失败。');
      }
    }

    function goBack() { window.history.back(); }
    function logout() { localStorage.removeItem('token'); window.location.href = '/admin'; }

    initTheme();
    loadCategories();
  </script>
</body>
</html>
