<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DevLog 系统设置</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '#6366f1',
            dark: {
              bg: '#0a0a0a',
              surface: '#111111',
              border: '#1f1f1f',
            },
          },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/admin/admin-common.css">
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-[#0a0a0a] dark:text-gray-100">
  <div id="admin-app"></div>

  <script src="/admin/admin-common.js"></script>
  <script>
    if (!window.AdminApp || !AdminApp.requireAuth()) {
      throw new Error('Missing admin auth context.');
    }

    const layout = AdminApp.mountPage({
      active: 'settings',
      title: '系统设置',
      description: '统一管理站点基础信息、作者资料、关于页内容、Markdown 主题和前台导航入口。',
      actions: [
        {
          id: 'open-sections-btn',
          label: '管理栏目',
          href: '/admin/sections',
          className: 'rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800',
        },
        {
          id: 'reload-settings-btn',
          label: '重新加载',
          className: 'rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800',
        },
        {
          id: 'save-settings-btn',
          label: '保存全部设置',
          className: 'rounded-xl bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-lg shadow-indigo-500/20 transition-colors hover:bg-indigo-700',
        },
      ],
    });

    layout.content.innerHTML = `
      <div class="grid gap-6">
        <section class="admin-panel p-6">
          <div class="admin-kicker text-gray-500 dark:text-gray-400">Site Basics</div>
          <h2 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">站点基础与 SEO</h2>
          <div class="mt-5 grid gap-4 lg:grid-cols-2">
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="siteName">站点名称</label>
              <input id="siteName" class="input-control" type="text">
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="author">默认作者</label>
              <input id="author" class="input-control" type="text">
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="email">联系邮箱</label>
              <input id="email" class="input-control" type="email">
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="postsPerPage">首页文章数量</label>
              <input id="postsPerPage" class="input-control" type="number" min="1" step="1">
            </div>
            <div class="lg:col-span-2">
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="description">站点描述</label>
              <textarea id="description" class="textarea-control" rows="4"></textarea>
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="metaKeywords">Meta Keywords</label>
              <input id="metaKeywords" class="input-control" type="text" placeholder="AI, Vue, 博客, 工程实践">
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="markdownTheme">Markdown 主题</label>
              <select id="markdownTheme" class="select-control">
                <option value="default">default</option>
                <option value="github-dark">github-dark</option>
              </select>
            </div>
            <div class="lg:col-span-2">
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="metaDescription">Meta Description</label>
              <textarea id="metaDescription" class="textarea-control" rows="3"></textarea>
            </div>
          </div>
        </section>

        <section class="admin-panel p-6">
          <div class="admin-kicker text-gray-500 dark:text-gray-400">Profile</div>
          <h2 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">前台个人资料</h2>
          <div class="mt-5 grid gap-4 lg:grid-cols-2">
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="profileName">展示名称</label>
              <input id="profileName" class="input-control" type="text">
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="profileSubtitle">副标题</label>
              <input id="profileSubtitle" class="input-control" type="text">
            </div>
            <div class="lg:col-span-2">
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="profileMotto">个人简介</label>
              <textarea id="profileMotto" class="textarea-control" rows="3"></textarea>
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="profileAvatar">头像 URL</label>
              <input id="profileAvatar" class="input-control" type="url">
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="profileGithub">GitHub</label>
              <input id="profileGithub" class="input-control" type="text">
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="profilePlanet">知识星球 / 外部主页</label>
              <input id="profilePlanet" class="input-control" type="text">
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="profileEmail">展示邮箱</label>
              <input id="profileEmail" class="input-control" type="email">
            </div>
          </div>
        </section>

        <section class="admin-panel p-6">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <div class="admin-kicker text-gray-500 dark:text-gray-400">About Page</div>
              <h2 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">关于页内容</h2>
            </div>
            <button id="add-skill-btn" type="button" class="rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800">新增技能项</button>
          </div>
          <div class="mt-5 grid gap-4 lg:grid-cols-2">
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="aboutTitle">关于标题</label>
              <input id="aboutTitle" class="input-control" type="text">
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="aboutSkillsTitle">技能区标题</label>
              <input id="aboutSkillsTitle" class="input-control" type="text">
            </div>
            <div class="lg:col-span-2">
              <label class="mb-2 block text-sm font-medium text-gray-700 dark:text-gray-300" for="aboutContent">关于正文</label>
              <textarea id="aboutContent" class="textarea-control" rows="5"></textarea>
            </div>
          </div>
          <div class="mt-6">
            <div class="mb-3 text-sm font-medium text-gray-700 dark:text-gray-300">技能列表</div>
            <div id="skills-list" class="space-y-3"></div>
          </div>
        </section>

        <section class="admin-panel p-6">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <div class="admin-kicker text-gray-500 dark:text-gray-400">Navigation</div>
              <h2 class="mt-1 text-lg font-semibold text-gray-900 dark:text-white">前台导航入口</h2>
              <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">这里管理首页导航与专栏入口。更细的栏目内容仍然在“栏目管理”页维护。</p>
            </div>
            <button id="add-nav-btn" type="button" class="rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-800">新增导航项</button>
          </div>
          <div id="nav-list" class="mt-5 space-y-4"></div>
        </section>
      </div>
    `;

    const state = {
      settings: {},
      skills: [],
      navItems: [],
    };

    function makeId(prefix) {
      return `${prefix}-${Date.now()}-${Math.random().toString(16).slice(2, 8)}`;
    }

    function normalizeNavHref(value) {
      let href = String(value || '').trim();
      if (!href) {
        return '';
      }
      if (/^https?:\/\//i.test(href)) {
        return href;
      }
      if (!href.startsWith('#')) {
        href = href.startsWith('/') ? `#${href}` : `#/${href}`;
      }
      return href;
    }

    function navHrefToUrl(value) {
      const href = normalizeNavHref(value);
      if (!href) {
        return '';
      }
      if (/^https?:\/\//i.test(href)) {
        return href;
      }
      return href.replace(/^#/, '') || '/';
    }

    function normalizeSkill(skill) {
      return {
        id: skill.id || makeId('skill'),
        label: String(skill.label || '').trim(),
        icon: String(skill.icon || '').trim(),
        color: String(skill.color || '').trim(),
      };
    }

    function normalizeNavItem(item, index) {
      const href = normalizeNavHref(item.href || item.url || '');
      return {
        id: item.id || makeId('nav'),
        label: String(item.label || item.name || '').trim(),
        href,
        cover: String(item.cover || '').trim(),
        visible: item.visible !== false && item.enabled !== false,
        order: Number(item.order || (index + 1)) || (index + 1),
      };
    }

    function renderSkills() {
      const container = document.getElementById('skills-list');
      if (!state.skills.length) {
        container.innerHTML = '<div class="rounded-2xl bg-gray-50 px-4 py-5 text-sm text-gray-500 dark:bg-gray-800/70 dark:text-gray-400">暂无技能项，点击右上角新增。</div>';
        return;
      }

      container.innerHTML = state.skills.map(function renderSkill(skill, index) {
        return `
          <div class="rounded-2xl border border-gray-200 p-4 dark:border-gray-800" data-skill-row="${skill.id}">
            <div class="mb-4 flex items-center justify-between gap-4">
              <div class="text-sm font-semibold text-gray-900 dark:text-white">技能项 ${index + 1}</div>
              <button type="button" class="text-sm font-medium text-rose-600 hover:text-rose-500 dark:text-rose-300" data-remove-skill="${skill.id}">删除</button>
            </div>
            <div class="grid gap-3 md:grid-cols-3">
              <input class="input-control" type="text" placeholder="展示名称" data-skill-field="label" value="${AdminApp.escapeHtml(skill.label)}">
              <input class="input-control" type="text" placeholder="Iconify 图标名" data-skill-field="icon" value="${AdminApp.escapeHtml(skill.icon)}">
              <input class="input-control" type="text" placeholder="颜色值，如 #34d399" data-skill-field="color" value="${AdminApp.escapeHtml(skill.color)}">
            </div>
          </div>
        `;
      }).join('');
    }

    function renderNavItems() {
      const container = document.getElementById('nav-list');
      if (!state.navItems.length) {
        container.innerHTML = '<div class="rounded-2xl bg-gray-50 px-4 py-5 text-sm text-gray-500 dark:bg-gray-800/70 dark:text-gray-400">暂无导航项，点击右上角新增。</div>';
        return;
      }

      container.innerHTML = state.navItems.map(function renderNavItem(item, index) {
        return `
          <div class="rounded-2xl border border-gray-200 p-4 dark:border-gray-800" data-nav-row="${item.id}">
            <div class="mb-4 flex items-center justify-between gap-4">
              <div>
                <div class="text-sm font-semibold text-gray-900 dark:text-white">导航项 ${index + 1}</div>
                <div class="mt-1 text-xs text-gray-500 dark:text-gray-400">支持内部 hash 路由，如 <code>#/about</code>、<code>#/design</code>，也支持外部链接。</div>
              </div>
              <button type="button" class="text-sm font-medium text-rose-600 hover:text-rose-500 dark:text-rose-300" data-remove-nav="${item.id}">删除</button>
            </div>
            <div class="grid gap-3 lg:grid-cols-2">
              <input class="input-control" type="text" placeholder="显示名称" data-nav-field="label" value="${AdminApp.escapeHtml(item.label)}">
              <input class="input-control" type="text" placeholder="导航地址" data-nav-field="href" value="${AdminApp.escapeHtml(item.href)}">
              <input class="input-control" type="number" min="1" step="1" placeholder="排序" data-nav-field="order" value="${item.order}">
              <input class="input-control" type="text" placeholder="封面图 URL（可选）" data-nav-field="cover" value="${AdminApp.escapeHtml(item.cover)}">
            </div>
            <label class="mt-4 inline-flex items-center gap-3 text-sm text-gray-700 dark:text-gray-300">
              <input type="checkbox" class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" data-nav-field="visible" ${item.visible ? 'checked' : ''}>
              在前台显示
            </label>
          </div>
        `;
      }).join('');
    }

    function fillForm(settings) {
      document.getElementById('siteName').value = settings.siteName || settings.blogName || '';
      document.getElementById('author').value = settings.author || '';
      document.getElementById('email').value = settings.email || '';
      document.getElementById('postsPerPage').value = settings.postsPerPage || 10;
      document.getElementById('description').value = settings.description || settings.blogDesc || '';
      document.getElementById('metaKeywords').value = settings.metaKeywords || '';
      document.getElementById('metaDescription').value = settings.metaDescription || '';
      document.getElementById('markdownTheme').value = settings.markdownTheme || 'default';

      const profile = settings.profile || {};
      document.getElementById('profileName').value = profile.name || '';
      document.getElementById('profileSubtitle').value = profile.subtitle || '';
      document.getElementById('profileMotto').value = profile.motto || '';
      document.getElementById('profileAvatar').value = profile.avatar || '';
      document.getElementById('profileGithub').value = profile.github || '';
      document.getElementById('profilePlanet').value = profile.planet || '';
      document.getElementById('profileEmail').value = profile.email || '';

      const about = settings.about || {};
      document.getElementById('aboutTitle').value = about.title || '';
      document.getElementById('aboutSkillsTitle').value = about.skillsTitle || '';
      document.getElementById('aboutContent').value = about.content || '';
    }

    function syncSkillsFromDom() {
      state.skills = Array.from(document.querySelectorAll('[data-skill-row]')).map(function mapRow(row) {
        return normalizeSkill({
          id: row.getAttribute('data-skill-row'),
          label: row.querySelector('[data-skill-field="label"]').value,
          icon: row.querySelector('[data-skill-field="icon"]').value,
          color: row.querySelector('[data-skill-field="color"]').value,
        });
      }).filter(function keepSkill(skill) {
        return skill.label;
      });
    }

    function syncNavItemsFromDom() {
      state.navItems = Array.from(document.querySelectorAll('[data-nav-row]')).map(function mapRow(row, index) {
        return normalizeNavItem({
          id: row.getAttribute('data-nav-row'),
          label: row.querySelector('[data-nav-field="label"]').value,
          href: row.querySelector('[data-nav-field="href"]').value,
          order: row.querySelector('[data-nav-field="order"]').value,
          cover: row.querySelector('[data-nav-field="cover"]').value,
          visible: row.querySelector('[data-nav-field="visible"]').checked,
        }, index);
      }).filter(function keepNav(item) {
        return item.label && item.href;
      });
    }

    function collectSettingsPayload() {
      syncSkillsFromDom();
      const siteName = document.getElementById('siteName').value.trim();
      if (!siteName) {
        throw new Error('站点名称不能为空。');
      }

      const description = document.getElementById('description').value.trim();

      return {
        ...state.settings,
        siteName: siteName,
        blogName: siteName,
        description: description,
        blogDesc: description,
        author: document.getElementById('author').value.trim(),
        email: document.getElementById('email').value.trim(),
        postsPerPage: Number(document.getElementById('postsPerPage').value) || 10,
        metaKeywords: document.getElementById('metaKeywords').value.trim(),
        metaDescription: document.getElementById('metaDescription').value.trim(),
        markdownTheme: document.getElementById('markdownTheme').value,
        profile: {
          ...(state.settings.profile || {}),
          name: document.getElementById('profileName').value.trim(),
          subtitle: document.getElementById('profileSubtitle').value.trim(),
          motto: document.getElementById('profileMotto').value.trim(),
          avatar: document.getElementById('profileAvatar').value.trim(),
          github: document.getElementById('profileGithub').value.trim(),
          planet: document.getElementById('profilePlanet').value.trim(),
          email: document.getElementById('profileEmail').value.trim(),
        },
        about: {
          ...(state.settings.about || {}),
          title: document.getElementById('aboutTitle').value.trim(),
          skillsTitle: document.getElementById('aboutSkillsTitle').value.trim(),
          content: document.getElementById('aboutContent').value.trim(),
          skills: state.skills,
        },
      };
    }

    function collectNavPayload() {
      syncNavItemsFromDom();
      return state.navItems
        .slice()
        .sort(function sortByOrder(a, b) { return a.order - b.order; })
        .map(function mapNavItem(item, index) {
          return {
            id: item.id,
            label: item.label,
            name: item.label,
            href: normalizeNavHref(item.href),
            url: navHrefToUrl(item.href),
            cover: item.cover,
            visible: item.visible,
            enabled: item.visible,
            order: Number(item.order || (index + 1)) || (index + 1),
          };
        });
    }

    async function loadAllSettings() {
      layout.setNotice('正在加载设置...', 'info');
      try {
        const results = await Promise.all([
          AdminApp.requestJson('/api/data/settings'),
          AdminApp.requestJson('/api/data/nav'),
        ]);

        state.settings = results[0] || {};
        state.skills = Array.isArray(state.settings.about && state.settings.about.skills)
          ? state.settings.about.skills.map(normalizeSkill)
          : [];
        state.navItems = (Array.isArray(results[1]) ? results[1] : []).map(normalizeNavItem);

        fillForm(state.settings);
        renderSkills();
        renderNavItems();
        layout.setNotice('设置已加载。', 'success');
      } catch (error) {
        layout.setNotice(`加载设置失败：${error.message}`, 'error');
      }
    }

    async function saveAllSettings() {
      layout.setNotice('正在保存设置...', 'info');
      try {
        const settingsPayload = collectSettingsPayload();
        const navPayload = collectNavPayload();

        await Promise.all([
          AdminApp.requestJson('/api/data/settings', {
            method: 'PUT',
            body: settingsPayload,
          }),
          AdminApp.requestJson('/api/data/nav', {
            method: 'PUT',
            body: navPayload,
          }),
        ]);

        state.settings = settingsPayload;
        state.navItems = navPayload.map(normalizeNavItem);
        renderSkills();
        renderNavItems();
        layout.setNotice('站点设置和导航入口已保存。', 'success');
      } catch (error) {
        layout.setNotice(`保存失败：${error.message}`, 'error');
      }
    }

    document.getElementById('reload-settings-btn').addEventListener('click', function reloadSettings() {
      loadAllSettings();
    });

    document.getElementById('save-settings-btn').addEventListener('click', function saveSettings() {
      saveAllSettings();
    });

    document.getElementById('add-skill-btn').addEventListener('click', function addSkill() {
      syncSkillsFromDom();
      state.skills.push(normalizeSkill({ label: '', icon: '', color: '' }));
      renderSkills();
    });

    document.getElementById('add-nav-btn').addEventListener('click', function addNavItem() {
      syncNavItemsFromDom();
      state.navItems.push(normalizeNavItem({
        label: '',
        href: '#/',
        order: state.navItems.length + 1,
        visible: true,
      }, state.navItems.length));
      renderNavItems();
    });

    document.getElementById('skills-list').addEventListener('click', function handleSkillListClick(event) {
      const button = event.target.closest('[data-remove-skill]');
      if (!button) return;
      syncSkillsFromDom();
      state.skills = state.skills.filter(function filterSkill(skill) {
        return skill.id !== button.getAttribute('data-remove-skill');
      });
      renderSkills();
    });

    document.getElementById('nav-list').addEventListener('click', function handleNavListClick(event) {
      const button = event.target.closest('[data-remove-nav]');
      if (!button) return;
      syncNavItemsFromDom();
      state.navItems = state.navItems.filter(function filterNav(item) {
        return item.id !== button.getAttribute('data-remove-nav');
      });
      renderNavItems();
    });

    loadAllSettings();
  </script>
</body>
</html>
