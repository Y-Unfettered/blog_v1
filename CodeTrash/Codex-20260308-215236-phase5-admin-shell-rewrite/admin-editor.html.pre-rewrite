<!DOCTYPE html>
<html lang="zh-CN" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>文章编辑 - DevLog</title>
  <link rel="stylesheet" href="https://unpkg.com/md-editor-v3@2.11.3/lib/style.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
  <script src="https://unpkg.com/md-editor-v3@2.11.3/lib/md-editor-v3.umd.js"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: '#6366f1',
            dark: {
              bg: '#0a0a0a',
              surface: '#111111',
              border: '#1f1f1f',
            }
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    
    .md-editor-dark { --md-editor-bg-color: #111111; --md-editor-color: #e5e7eb; --md-editor-border-color: #1f1f1f; }
    .md-editor { border-radius: 12px; overflow: hidden; }
    
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    .dark ::-webkit-scrollbar-thumb { background: #374151; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    .dark ::-webkit-scrollbar-thumb:hover { background: #4b5563; }
  </style>
</head>
<body class="bg-gray-50 text-gray-900 dark:bg-dark-bg dark:text-gray-100 transition-colors duration-200">
  <div id="app" class="min-h-screen">
    <!-- 顶部导航 -->
    <header class="sticky top-0 z-50 bg-white dark:bg-dark-surface border-b border-gray-200 dark:border-dark-border transition-colors duration-200">
      <div class="flex items-center justify-between px-6 h-16">
        <div class="flex items-center gap-3">
          <button onclick="goBack()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors">
            <svg class="w-5 h-5 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
          </button>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center shadow-lg shadow-indigo-500/20">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
            </div>
            <h1 class="text-xl font-bold text-gray-900 dark:text-white">文章编辑</h1>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <!-- 主题切换按钮 -->
          <button onclick="toggleTheme()" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors" title="切换主题">
            <svg id="themeIcon" class="w-5 h-5 text-gray-600 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
            </svg>
          </button>
          <button @click="saveDraft" class="px-4 py-2 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-xl transition-colors text-sm font-medium text-gray-700 dark:text-gray-300">
            保存草稿
          </button>
          <button @click="publishPost" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-xl transition-colors text-sm font-medium text-white shadow-lg shadow-indigo-500/20">
            {{ isEditing ? '更新文章' : '发布文章' }}
          </button>
        </div>
      </div>
    </header>

    <!-- 主内容区 -->
    <main class="p-6">
      <div class="max-w-6xl mx-auto space-y-6">
        <!-- 标题和元信息 -->
        <div class="bg-white dark:bg-dark-surface border border-gray-200 dark:border-dark-border rounded-xl p-5 transition-colors duration-200">
          <div class="space-y-4">
            <div>
              <input 
                v-model="post.title" 
                type="text" 
                placeholder="输入文章标题..." 
                class="w-full text-2xl font-bold bg-transparent border-none outline-none text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500"
              />
            </div>
            <div class="flex flex-wrap gap-4">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
                </svg>
                <select v-model="post.categoryId" class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                  <option value="">选择分类</option>
                  <option v-for="cat in categories" :key="cat.id" :value="cat.id">{{ cat.name }}</option>
                </select>
              </div>
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                </svg>
                <input 
                  v-model="post.tags" 
                  type="text" 
                  placeholder="标签，用逗号分隔" 
                  class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-700 dark:text-gray-300 focus:outline-none focus:ring-2 focus:ring-indigo-500 w-64"
                />
              </div>
            </div>
          </div>
        </div>

        <!--  Markdown 编辑器 -->
        <div class="bg-white dark:bg-dark-surface border border-gray-200 dark:border-dark-border rounded-xl overflow-hidden transition-colors duration-200">
          <md-editor 
            v-model="post.content" 
            :theme="darkMode ? 'dark' : 'light'"
            language="zh-CN"
            :toolbars="toolbars"
            @on-upload-img="onUploadImg"
            class="border-0"
          />
        </div>
      </div>
    </main>
  </div>

  <script>
    const { createApp, ref, onMounted, computed } = Vue;

    createApp({
      setup() {
        const post = ref({
          id: '',
          title: '',
          content: '',
          categoryId: '',
          tags: '',
          status: 'draft'
        });
        
        const categories = ref([]);
        const isEditing = ref(false);
        const darkMode = ref(true);

        const toolbars = [
          'bold', 'underline', 'italic', 'strikeThrough', '-', 
          'title', 'quote', 'ul', 'ol', 'task', '-', 
          'link', 'image', 'table', 'mermaid', 'codeRow', 'code', '-',
          'revoke', 'next', 'save', '=',
          'pageFullscreen', 'fullscreen', 'preview', 'htmlPreview'
        ];

        const onUploadImg = async (files, callback) => {
          // 图片上传逻辑
          console.log('上传图片:', files);
        };

        const buildPostPayload = (status) => {
          const categoryId = String(post.value.categoryId || '').trim();
          const tags = String(post.value.tags || '')
            .split(',')
            .map((item) => item.trim())
            .filter(Boolean);

          return {
            ...post.value,
            categories: categoryId ? [categoryId] : [],
            categoryIds: categoryId ? [categoryId] : [],
            categoryId,
            tags,
            tagIds: tags,
            status,
            published: status === 'published'
          };
        };

        const saveDraft = async () => {
          if (!post.value.title.trim()) {
            alert('请输入文章标题');
            return;
          }
          
          try {
            const token = localStorage.getItem('token');
            const url = isEditing.value ? `/api/data/posts/${post.value.id}` : '/api/data/posts';
            const method = isEditing.value ? 'PATCH' : 'POST';
            
            const response = await fetch(url, {
              method,
              headers: {
                'Content-Type': 'application/json',
                Authorization: `Bearer ${token}`
              },
              body: JSON.stringify(buildPostPayload('draft'))
            });
            
            if (response.ok) {
              alert('草稿已保存');
              if (!isEditing.value) {
                const data = await response.json();
                post.value.id = data.id || data.postId;
                isEditing.value = true;
              }
            } else {
              alert('保存失败');
            }
          } catch (error) {
            console.error('保存草稿失败:', error);
            alert('保存失败，请重试');
          }
        };

        const publishPost = async () => {
          if (!post.value.title.trim()) {
            alert('请输入文章标题');
            return;
          }
          
          if (!post.value.content.trim()) {
            alert('请输入文章内容');
            return;
          }

          if (!confirm('确定要发布这篇文章吗？')) return;
          
          try {
            const token = localStorage.getItem('token');
            const url = isEditing.value ? `/api/data/posts/${post.value.id}` : '/api/data/posts';
            const method = isEditing.value ? 'PATCH' : 'POST';
            
            const response = await fetch(url, {
              method,
              headers: {
                'Content-Type': 'application/json',
                Authorization: `Bearer ${token}`
              },
              body: JSON.stringify(buildPostPayload('published'))
            });
            
            if (response.ok) {
              alert('文章已发布！');
              window.location.href = '/admin/posts.html';
            } else {
              alert('发布失败');
            }
          } catch (error) {
            console.error('发布文章失败:', error);
            alert('发布失败，请重试');
          }
        };

        const loadPost = async (postId) => {
          try {
            const token = localStorage.getItem('token');
            const response = await fetch(`/api/data/posts/${postId}`, {
              headers: { Authorization: `Bearer ${token}` }
            });
            
            if (response.ok) {
              const data = await response.json();
              post.value = {
                id: data.id || postId,
                title: data.title || '',
                content: data.content || '',
                categoryId: data.categoryId || data.categories?.[0] || data.categoryIds?.[0] || '',
                tags: Array.isArray(data.tags)
                  ? data.tags.join(', ')
                  : (Array.isArray(data.tagIds) ? data.tagIds.join(', ') : (data.tags || '')),
                status: data.status || 'draft'
              };
              isEditing.value = true;
            }
          } catch (error) {
            console.error('加载文章失败:', error);
          }
        };

        const loadCategories = async () => {
          try {
            const token = localStorage.getItem('token');
            const response = await fetch('/api/data/categories', {
              headers: { Authorization: `Bearer ${token}` }
            });
            
            if (response.ok) {
              categories.value = await response.json();
            }
          } catch (error) {
            console.error('加载分类失败:', error);
          }
        };

        const goBack = () => {
          window.history.back();
        };

        onMounted(() => {
          // 检测主题
          darkMode.value = localStorage.getItem('theme') === 'dark' || !localStorage.getItem('theme');
          
          // 加载分类
          loadCategories();
          
          // 检查是否是编辑模式
          const params = new URLSearchParams(window.location.search);
          const postId = params.get('id');
          if (postId) {
            loadPost(postId);
          }
        });

        return {
          post,
          categories,
          isEditing,
          darkMode,
          toolbars,
          onUploadImg,
          saveDraft,
          publishPost,
          goBack
        };
      }
    }).mount('#app');

    // ========== 主题切换 ==========
    let currentTheme = localStorage.getItem('theme') || 'dark';
    
    function initTheme() {
      setTheme(currentTheme);
    }
    
    function toggleTheme() {
      currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
      setTheme(currentTheme);
      // 更新 Vue 应用中的 darkMode 状态
      const app = Vue.getCurrentInstance()?.appContext?.app?._instance?.proxy;
      if (app) {
        app.darkMode = currentTheme === 'dark';
      }
    }
    
    function setTheme(theme) {
      currentTheme = theme;
      localStorage.setItem('theme', theme);
      const html = document.documentElement;
      const icon = document.getElementById('themeIcon');
      
      html.classList.remove('light', 'dark');
      html.classList.add(theme);
      
      if (theme === 'dark') {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>';
      } else {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>';
      }
    }
    
    // 初始化主题
    initTheme();
  </script>
</body>
</html>
