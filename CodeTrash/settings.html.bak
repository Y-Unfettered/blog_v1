<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>后台管理 - 系统设置</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#6366f1',
            dark: {
              100: '#1e293b',
              200: '#172033',
              300: '#0f1115',
              400: '#0a0c10',
            }
          }
        }
      }
    };
  </script>
  <style>
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }
    .sidebar-item {
      transition: all 0.3s ease;
    }
    .sidebar-item:hover {
      background: rgba(99, 102, 241, 0.1);
      border-right: 3px solid #6366f1;
    }
    .sidebar-item.active {
      background: rgba(99, 102, 241, 0.2);
      border-right: 3px solid #6366f1;
      color: #818cf8;
    }
  </style>
</head>
<body class="bg-[#0f1115] text-gray-300 min-h-screen">
  <header class="sticky top-0 z-50 bg-[#0f1115]/80 backdrop-blur-xl border-b border-gray-800">
    <div class="flex items-center justify-between px-6 h-16">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
        </div>
        <h1 class="text-xl font-bold text-white">DevLog 后台管理</h1>
      </div>
      <div class="flex items-center gap-4">
        <button onclick="goBack()" class="flex items-center gap-2 px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          返回
        </button>
        <button onclick="logout()" class="flex items-center gap-2 px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-lg transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
          </svg>
          退出
        </button>
      </div>
    </div>
  </header>

  <div class="flex min-h-[calc(100vh-64px)]">
    <aside class="w-64 bg-[#0a0c10] border-r border-gray-800">
      <nav class="py-4">
        <div class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3" onclick="goToDashboard()">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
          </svg>
          <span>概览</span>
        </div>
        <div class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3" onclick="goToPosts()">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          <span>文章管理</span>
        </div>
        <div class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3" onclick="goToCategories()">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
          </svg>
          <span>分类管理</span>
        </div>
        <div class="sidebar-item px-6 py-3 cursor-pointer flex items-center gap-3" onclick="goToTags()">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
          </svg>
          <span>标签管理</span>
        </div>
        <div class="sidebar-item active px-6 py-3 cursor-pointer flex items-center gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <span>系统设置</span>
        </div>
      </nav>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-white">系统设置</h2>
        <button onclick="saveSettings()" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg transition-all">
          保存设置
        </button>
      </div>

      <div id="statusMessage" class="hidden mb-6 px-4 py-3 rounded-lg text-sm"></div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <section class="bg-[#111] border border-gray-800 rounded-xl p-6 space-y-4">
          <h3 class="text-white font-semibold">站点信息</h3>
          <div>
            <label class="block text-sm text-gray-400 mb-2">站点名称</label>
            <input id="siteName" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-2">站点描述</label>
            <textarea id="description" rows="3" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500"></textarea>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm text-gray-400 mb-2">作者</label>
              <input id="author" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
            </div>
            <div>
              <label class="block text-sm text-gray-400 mb-2">联系邮箱</label>
              <input id="email" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
            </div>
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-2">Markdown 主题</label>
            <select id="markdownTheme" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500">
              <option value="default">default</option>
              <option value="github">github</option>
            </select>
          </div>
        </section>

        <section class="bg-[#111] border border-gray-800 rounded-xl p-6 space-y-4">
          <h3 class="text-white font-semibold">个人卡片</h3>
          <div>
            <label class="block text-sm text-gray-400 mb-2">名称</label>
            <input id="profileName" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-2">副标题</label>
            <input id="profileSubtitle" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-2">格言</label>
            <textarea id="profileMotto" rows="3" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500"></textarea>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm text-gray-400 mb-2">头像 URL</label>
              <input id="profileAvatar" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
            </div>
            <div>
              <label class="block text-sm text-gray-400 mb-2">展示邮箱</label>
              <input id="profileEmail" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm text-gray-400 mb-2">GitHub URL</label>
              <input id="profileGithub" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
            </div>
            <div>
              <label class="block text-sm text-gray-400 mb-2">星球 URL</label>
              <input id="profilePlanet" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
            </div>
          </div>
        </section>

        <section class="bg-[#111] border border-gray-800 rounded-xl p-6 space-y-4 xl:col-span-2">
          <h3 class="text-white font-semibold">关于页</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm text-gray-400 mb-2">标题</label>
              <input id="aboutTitle" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
            </div>
            <div>
              <label class="block text-sm text-gray-400 mb-2">技能标题</label>
              <input id="aboutSkillsTitle" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500" />
            </div>
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-2">内容</label>
            <textarea id="aboutContent" rows="4" class="w-full px-4 py-2.5 bg-gray-800 border border-gray-700 rounded-lg text-white focus:outline-none focus:border-indigo-500"></textarea>
          </div>
        </section>
      </div>
    </main>
  </div>

  <script>
    const token = localStorage.getItem('token');
    if (!token) {
      window.location.href = '/admin';
    }

    let settingsData = {};

    function showStatus(message, isError) {
      const box = document.getElementById('statusMessage');
      box.textContent = message;
      box.classList.remove('hidden', 'bg-emerald-500/10', 'border-emerald-500/30', 'text-emerald-300', 'bg-red-500/10', 'border-red-500/30', 'text-red-300', 'border');
      if (isError) {
        box.classList.add('bg-red-500/10', 'border', 'border-red-500/30', 'text-red-300');
      } else {
        box.classList.add('bg-emerald-500/10', 'border', 'border-emerald-500/30', 'text-emerald-300');
      }
    }

    async function fetchSettings() {
      const response = await fetch('/api/data/settings', {
        headers: {
          Authorization: `Bearer ${token}`,
        },
      });
      if (response.status === 401) {
        logout();
        return {};
      }
      if (!response.ok) {
        throw new Error('加载设置失败');
      }
      return await response.json();
    }

    async function persistSettings(data) {
      const response = await fetch('/api/data/settings', {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify(data),
      });
      if (!response.ok) {
        throw new Error('保存设置失败');
      }
    }

    function fillForm(data) {
      const profile = data.profile || {};
      const about = data.about || {};

      document.getElementById('siteName').value = data.siteName || '';
      document.getElementById('description').value = data.description || '';
      document.getElementById('author').value = data.author || '';
      document.getElementById('email').value = data.email || '';
      document.getElementById('markdownTheme').value = data.markdownTheme || 'default';

      document.getElementById('profileName').value = profile.name || '';
      document.getElementById('profileSubtitle').value = profile.subtitle || '';
      document.getElementById('profileMotto').value = profile.motto || '';
      document.getElementById('profileAvatar').value = profile.avatar || '';
      document.getElementById('profileEmail').value = profile.email || '';
      document.getElementById('profileGithub').value = profile.github || '';
      document.getElementById('profilePlanet').value = profile.planet || '';

      document.getElementById('aboutTitle').value = about.title || '';
      document.getElementById('aboutSkillsTitle').value = about.skillsTitle || '';
      document.getElementById('aboutContent').value = about.content || '';
    }

    async function saveSettings() {
      const next = {
        ...settingsData,
        siteName: String(document.getElementById('siteName').value || '').trim(),
        description: String(document.getElementById('description').value || '').trim(),
        author: String(document.getElementById('author').value || '').trim(),
        email: String(document.getElementById('email').value || '').trim(),
        markdownTheme: String(document.getElementById('markdownTheme').value || 'default').trim() || 'default',
        profile: {
          ...(settingsData.profile || {}),
          name: String(document.getElementById('profileName').value || '').trim(),
          subtitle: String(document.getElementById('profileSubtitle').value || '').trim(),
          motto: String(document.getElementById('profileMotto').value || '').trim(),
          avatar: String(document.getElementById('profileAvatar').value || '').trim(),
          email: String(document.getElementById('profileEmail').value || '').trim(),
          github: String(document.getElementById('profileGithub').value || '').trim(),
          planet: String(document.getElementById('profilePlanet').value || '').trim(),
        },
        about: {
          ...(settingsData.about || {}),
          title: String(document.getElementById('aboutTitle').value || '').trim(),
          skillsTitle: String(document.getElementById('aboutSkillsTitle').value || '').trim(),
          content: String(document.getElementById('aboutContent').value || '').trim(),
        },
      };

      try {
        await persistSettings(next);
        settingsData = next;
        showStatus('设置已保存', false);
      } catch (error) {
        console.error(error);
        showStatus('保存失败，请检查后端服务状态', true);
      }
    }

    async function initPage() {
      try {
        settingsData = await fetchSettings();
        if (!settingsData || typeof settingsData !== 'object' || Array.isArray(settingsData)) {
          settingsData = {};
        }
        fillForm(settingsData);
      } catch (error) {
        console.error(error);
        showStatus('加载设置失败，请刷新后重试', true);
      }
    }

    function goBack() {
      window.location.href = '/admin/dashboard.html';
    }
    function goToDashboard() {
      window.location.href = '/admin/dashboard.html';
    }
    function goToPosts() {
      window.location.href = '/admin/posts.html';
    }
    function goToCategories() {
      window.location.href = '/admin/categories.html';
    }
    function goToTags() {
      window.location.href = '/admin/tags.html';
    }
    function logout() {
      localStorage.removeItem('token');
      window.location.href = '/admin';
    }

    initPage();
  </script>
</body>
</html>
